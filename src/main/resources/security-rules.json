      ],
      "codeExamples": {
        "bad": "// ❌ 취약하거나 위험한 API 사용\n// Thread.stop()          — 비결정적 상태 유발\n// System.runFinalizersOnExit(true) — 비권고 API\n// Runtime.exec(String)   — 쉘 삽입 위험 (배열 형태 미사용)\nRuntime.getRuntime().exec(\"ls \" + userInput);",
        "good": "// ✅ 안전한 대안 API 사용\n// Thread.stop() 대신 → 인터럽트 메커니즘\nthread.interrupt();\n\n// Runtime.exec(String) 대신 → 배열 형태 사용\nString[] cmd = {\"ls\", \"-l\", safeDir};\nProcess proc = Runtime.getRuntime().exec(cmd);\n\n// 또는 ProcessBuilder 사용 (권장)\nProcessBuilder pb = new ProcessBuilder(\"ls\", \"-l\", safeDir);\npb.redirectErrorStream(true);\nProcess p = pb.start();"
      }
