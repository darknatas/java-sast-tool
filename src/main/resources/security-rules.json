      "remediation": {
        "strategy": "CSRF_TOKEN",
        "description": "중요 기능 요청에 CSRF 토큰 생성·검증 또는 SameSite 쿠키 속성 적용",
        "guideRef": "PART4 제1절 11항 (p.272-275)",
        "remediationCode": "// [수정] IV-1.11 CSRF 방지: Synchronizer Token 패턴 구현\n// ❌ 취약: POST 요청에 CSRF 토큰 검증 없음\nprotected void doPost(HttpServletRequest req, ...) {\n    userService.delete(req.getParameter(\"userId\"));\n}\n\n// ✅ 안전: 토큰 생성 + 검증\n// [로그인 시 생성]\nbyte[] bytes = new byte[32];\nnew SecureRandom().nextBytes(bytes);\nsession.setAttribute(\"_csrf\",\n    Base64.getUrlEncoder().withoutPadding().encodeToString(bytes));\n// [폼 히든 필드]\n// <input type=\"hidden\" name=\"_csrf\" value=\"${sessionScope._csrf}\">\n// [POST 검증]\nString req = request.getParameter(\"_csrf\");\nString ses = (String) session.getAttribute(\"_csrf\");\nif (!MessageDigest.isEqual(req.getBytes(), ses.getBytes()))\n    throw new SecurityException(\"CSRF 토큰 불일치\");\n// Spring Security: 자동 처리 (@EnableWebSecurity)"
      },
      "dangerousPatterns": [
        "void doPost\\(HttpServletRequest|void doPut\\(|void doDelete\\("
      ],
      "codeExamples": {
        "bad": "// ❌ CSRF 토큰 없는 상태 변경 요청\n// POST /deleteAccount — 토큰 검증 없음\npublic void deleteAccount(HttpServletRequest req) {\n    String userId = (String) req.getSession().getAttribute(\"userId\");\n    userService.delete(userId);\n}",
        "good": "// ✅ Synchronizer Token 패턴으로 CSRF 방어\npublic void deleteAccount(HttpServletRequest req) {\n    HttpSession session = req.getSession(false);\n    String expected = (String) session.getAttribute(\"csrfToken\");\n    String received = req.getParameter(\"csrfToken\");\n    if (expected == null || !expected.equals(received)) {\n        throw new SecurityException(\"CSRF 토큰 불일치\");\n    }\n    String userId = (String) session.getAttribute(\"userId\");\n    userService.delete(userId);\n}"
      }
