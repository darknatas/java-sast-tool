        "bad_code": "// ❌ 중요 정보(비밀번호) 평문 저장\nuserDao.save(new User(id, password)); // password를 그대로 DB에 저장",
        "good_code": "// ✅ PBKDF2 + Salt 해시 저장\nbyte[] salt = new byte[16];\nnew SecureRandom().nextBytes(salt);\nSecretKeyFactory skf = SecretKeyFactory.getInstance(\"PBKDF2WithHmacSHA256\");\nKeySpec ks = new PBEKeySpec(password.toCharArray(), salt, 310000, 256);\nbyte[] hash = skf.generateSecret(ks).getEncoded();\nString encoded = Base64.getEncoder().encodeToString(salt)\n                 + \":\" + Base64.getEncoder().encodeToString(hash);\nuserDao.save(new User(id, encoded));",
        "reference_url": "https://cwe.mitre.org/data/definitions/312.html"
      }
