        "guideRef": "PART4 제6절 2항 (p.476-480)",
        "remediationCode": "// [수정] IV-6.2 디버그 코드 제거: SLF4J 표준 로거로 교체\n// ❌ 취약: 배포 코드에 남은 디버그 출력\nSystem.out.println(\"userId = \" + userId);\nSystem.out.println(\"DB 쿼리: \" + sql);\ne.printStackTrace();  // 스택트레이스 노출 위험\n\n// ✅ 안전: SLF4J/Logback 표준 로거 사용\nprivate static final Logger log =\n    LoggerFactory.getLogger(MyService.class);\n\n// 개발 디버깅 (운영 환경에서 DEBUG 자동 비활성)\nlog.debug(\"userId={}\", userId);\nlog.debug(\"SQL: {}\", sql);\n\n// 예외 처리 (스택트레이스는 서버 로그에만)\n} catch (Exception e) {\n    log.error(\"[SERVICE] 처리 오류: {}\", e.getMessage(), e);\n    throw new ServiceException(\"서비스 오류\", e);\n}\n// logback.xml: <root level=\"WARN\"> (운영), <root level=\"DEBUG\"> (개발)"
