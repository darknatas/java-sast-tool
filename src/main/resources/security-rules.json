        "remediationCode": "// [수정] IV-6.3 private 배열 직접 반환 금지: 방어적 복사\n// ❌ 취약: private 배열 참조를 그대로 반환 → 외부에서 수정 가능\npublic class Config {\n    private String[] allowedRoles = {\"USER\", \"ADMIN\"};\n    public String[] getAllowedRoles() {\n        return allowedRoles;  // 외부: allowedRoles[0]=\"HACKER\" 가능!\n    }\n}\n\n// ✅ 안전 방법 1: Arrays.copyOf()로 방어적 복사\npublic class Config {\n    private String[] allowedRoles = {\"USER\", \"ADMIN\"};\n    public String[] getAllowedRoles() {\n        return Arrays.copyOf(allowedRoles, allowedRoles.length);\n    }\n}\n// ✅ 안전 방법 2: 불변 컬렉션 반환 (권장)\npublic List<String> getAllowedRoleList() {\n    return Collections.unmodifiableList(Arrays.asList(allowedRoles));\n}"
