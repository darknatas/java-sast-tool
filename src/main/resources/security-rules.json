      ],
      "remediation": {
        "strategy": "SALTED_HASH",
        "description": "bcrypt, PBKDF2, Argon2 등 솔트를 포함하는 해시 함수 사용",
        "guideRef": "PART4 제2절 14항 (p.391-394)",
        "remediationCode": "// [수정] IV-2.14 솔트 없는 해시 방지: 적응형 해시 함수 사용\n// ❌ 취약: 솔트 없이 MD5·SHA-1 단순 해시\nString hash = DigestUtils.md5Hex(password);  // 레인보우 테이블 취약\n\n// ✅ 안전 방법 1: BCrypt (Spring Security, 권장)\nBCryptPasswordEncoder enc = new BCryptPasswordEncoder(12);\nString stored = enc.encode(rawPassword);  // 솔트 자동 포함\nboolean match = enc.matches(rawPassword, stored);\n\n// ✅ 안전 방법 2: PBKDF2WithHmacSHA256\nSecretKeyFactory skf = SecretKeyFactory\n    .getInstance(\"PBKDF2WithHmacSHA256\");\nbyte[] salt = new byte[16];\nnew SecureRandom().nextBytes(salt);\nKeySpec spec = new PBEKeySpec(\n    password.toCharArray(), salt, 310000, 256);\nbyte[] hash = skf.generateSecret(spec).getEncoded();\n// salt와 hash를 함께 저장 (구분자 사용)"
      },
      "dangerousPatterns": [
