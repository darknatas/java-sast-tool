// security-rules.json — 행정안전부 소프트웨어 보안약점 진단가이드 2021
// PART3 (DS-x.x): 설계단계 20개 항목 | PART4 (IV-x.x): 구현단계 49개 항목
{
  "version": "2021.1",
  "source": "소프트웨어 보안약점 진단가이드 (2021), 행정안전부",
  "rules": [
    {
      "ruleId": "DS-1.1",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "DBMS 조회 및 결과 검증",
      "cwe": [
        "CWE-89"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "SQL 질의문 내 입력값 유효성 검증 및 바인딩 방식 적용 설계",
      "relatedImplRules": [
        "IV-1.1"
      ],
      "dangerousPatterns": [
        "executeQuery\\(|executeUpdate\\(|Statement.*execute"
      ],
      "remediation": {
        "strategy": "USE_PREPARED_STATEMENT",
        "description": "SQL 질의문에 외부에서 전달된 사용자 입력값이 검증 없이 직접 포함될 경우 SQL 삽입 취약점이 발생한다. 공격자는 입력값에 SQL 메타 문자를 삽입하여 데이터베이스의 모든 데이터를 조회·변조·삭제하거나 관리자 권한을 탈취할 수 있다. 설계 단계에서 SQL 질의에 외부 입력값을 직접 연결하는 방식을 금지하고 파라미터 바인딩 방식만 허용하도록 설계해야 한다. PreparedStatement의 ?·플레이스홀더, MyBatis의 #{ } 바인딩 등 SQL 구조와 데이터를 분리하는 방식을 표준으로 적용해야 한다.",
        "guideRef": "PART3 제1절 1항 (p.47-55)",
        "bad_code": "// ❌ SQL 문자열에 외부 입력값 직접 연결\nString sql = \"SELECT * FROM user WHERE id='\" + id + \"'\";\nStatement stmt = con.createStatement();\nResultSet rs = stmt.executeQuery(sql);",
        "good_code": "// ✅ PreparedStatement 파라미터 바인딩\nString sql = \"SELECT * FROM user WHERE id = ?\";\nPreparedStatement ps = con.prepareStatement(sql);\nps.setString(1, id);\nResultSet rs = ps.executeQuery();\n// MyBatis: WHERE id = #{id}  (${id} 사용 금지)",
        "reference_url": "https://cwe.mitre.org/data/definitions/89.html"
      }
    },
    {
      "ruleId": "DS-1.2",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "XML 조회 및 결과 검증",
      "cwe": [
        "CWE-652",
        "CWE-643"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "XPath·XQuery 질의문에 사용되는 파라미터 필터링 또는 바인딩 설계",
      "relatedImplRules": [
        "IV-1.9",
        "IV-1.10"
      ],
      "dangerousPatterns": [
        "xpath\\.evaluate|XPath\\.compile|executeXPath"
      ],
      "remediation": {
        "strategy": "PARAMETERIZED_XPATH",
        "description": "XPath 또는 XQuery 질의문에 외부 입력값이 검증 없이 삽입되면 XPath 삽입 취약점이 발생한다. 공격자는 XPath 메타 문자(', \", [ ] 등)를 포함한 입력값으로 쿼리 구조를 변조하여 인증 우회, 민감 XML 데이터 전체 조회 등의 공격을 수행할 수 있다. 이 취약점은 LDAP 조회 우회, 로그인 인증 우회, 기밀 데이터 노출 등의 피해를 일으킬 수 있다. 설계 단계에서 XPath 변수 바인딩(XPathVariableResolver) 또는 입력값의 특수문자 화이트리스트 검증을 의무화해야 한다.",
        "guideRef": "PART3 제1절 2항 (p.56-62)",
        "bad_code": "// ❌ 외부 입력값을 XPath 표현식에 직접 삽입\nString expr = \"/users/user[name='\" + userName + \"']\";\nNodeList nl = (NodeList) xpath.evaluate(expr, doc, XPathConstants.NODESET);",
        "good_code": "// ✅ 특수문자 제거 후 화이트리스트 검증\nString safe = userName.replaceAll(\"[^a-zA-Z0-9가-힣]\", \"\");\nif (!safe.matches(\"[a-zA-Z0-9가-힣]{1,50}\")) {\n    throw new IllegalArgumentException(\"허용되지 않은 입력값\");\n}\nString expr = \"/users/user[name='\" + safe + \"']\";\nNodeList nl = (NodeList) xpath.evaluate(expr, doc, XPathConstants.NODESET);",
        "reference_url": "https://cwe.mitre.org/data/definitions/652.html"
      }
    },
    {
      "ruleId": "DS-1.3",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "디렉토리 서비스 조회 및 결과 검증",
      "cwe": [
        "CWE-90"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "LDAP 질의에 사용되는 입력값 필터링 설계",
      "relatedImplRules": [
        "IV-1.10"
      ],
      "dangerousPatterns": [
        "DirContext|InitialDirContext|\\.search\\("
      ],
      "remediation": {
        "strategy": "LDAP_ENCODING",
        "description": "LDAP 질의에 외부 입력값이 필터링 없이 직접 삽입되면 LDAP 삽입 취약점이 발생한다. 공격자는 LDAP 특수문자(*, (, ), \\, NUL)를 포함한 입력으로 필터 로직을 변조하여 인증 우회, 디렉터리 서비스의 모든 사용자 정보 조회 등의 공격이 가능하다. 이는 조직 내 Active Directory나 LDAP 서버의 사용자 계정 정보 전체 노출로 이어질 수 있다. 설계 단계에서 LDAP 필터에 사용되는 모든 입력값에 RFC 4515 기반 특수문자 인코딩을 적용하도록 설계해야 한다.",
        "guideRef": "PART3 제1절 3항 (p.63-68)",
        "bad_code": "// ❌ 외부 입력값을 LDAP 필터에 직접 삽입\nString filter = \"(uid=\" + userName + \")\";\nNamingEnumeration<?> result = ctx.search(base, filter, controls);",
        "good_code": "// ✅ LDAP 특수문자 이스케이프 후 삽입\nString safe = userName.replaceAll(\"[\\\\*\\\\(\\\\)\\\\\\\\\\0]\", \"\");\nString filter = \"(uid=\" + safe + \")\";\nNamingEnumeration<?> result = ctx.search(base, filter, controls);\n// 또는 Spring Security LdapUtils.escapeLdapSearchFilter() 활용",
        "reference_url": "https://cwe.mitre.org/data/definitions/90.html"
      }
    },
    {
      "ruleId": "DS-1.4",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "시스템 자원 접근 및 명령어 수행 입력값 검증",
      "cwe": [
        "CWE-78",
        "CWE-22",
        "CWE-99"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "파일 경로·OS 명령어에 사용되는 외부 입력값 검증 설계",
      "relatedImplRules": [
        "IV-1.3",
        "IV-1.5"
      ],
      "dangerousPatterns": [
        "Runtime\\.getRuntime\\(\\)\\.exec|new ProcessBuilder"
      ],
      "remediation": {
        "strategy": "AVOID_OS_COMMAND",
        "description": "파일 경로나 OS 명령어 문자열에 외부 입력값이 검증 없이 포함되면 경로 조작 및 명령어 삽입 취약점이 발생한다. 공격자는 '../'를 삽입하여 허용 디렉터리를 벗어나거나, '; rm -rf /'와 같은 셸 메타 문자로 임의 OS 명령어를 실행할 수 있다. 이는 서버 파일 시스템 전체 접근, 악성코드 설치, 서비스 완전 장악으로 이어질 수 있는 매우 위험한 취약점이다. 설계 단계에서 외부 입력값으로 OS 명령어를 구성하는 것을 금지하고, 불가피한 경우 화이트리스트 검증과 ProcessBuilder 배열 방식을 의무화해야 한다.",
        "guideRef": "PART3 제1절 4항 (p.69-76)",
        "bad_code": "// ❌ 외부 입력값을 OS 명령어에 직접 삽입\nString cmd = \"cmd.exe /c ping \" + ipAddress;\nRuntime.getRuntime().exec(cmd);",
        "good_code": "// ✅ Java API 직접 사용 (OS 명령어 우회)\nInetAddress addr = InetAddress.getByName(ipAddress);\nboolean reachable = addr.isReachable(3000);\n// 불가피하게 exec() 사용 시: 화이트리스트 검증\nif (!ipAddress.matches(\"^\\\\d{1,3}(\\\\.\\\\d{1,3}){3}$\")) {\n    throw new IllegalArgumentException(\"잘못된 IP 주소\");\n}\nString[] cmd = {\"ping\", \"-c\", \"1\", ipAddress};\nRuntime.getRuntime().exec(cmd);",
        "reference_url": "https://cwe.mitre.org/data/definitions/78.html"
      }
    },
    {
      "ruleId": "DS-1.5",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "웹 서비스 요청 및 결과 검증",
      "cwe": [
        "CWE-79"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "웹 서비스 응답 데이터 XSS 필터링 및 인코딩 설계",
      "relatedImplRules": [
        "IV-1.4"
      ],
      "dangerousPatterns": [
        "out\\.print\\(|response\\.getWriter"
      ],
      "remediation": {
        "strategy": "OUTPUT_ENCODING",
        "description": "웹 서비스가 외부 입력값을 HTML 응답에 인코딩 없이 출력하면 크로스사이트 스크립트(XSS) 취약점이 발생한다. 공격자는 스크립트가 포함된 입력값을 주입하여 피해자 브라우저에서 악성 JavaScript를 실행시키고, 세션 쿠키 탈취·피싱·악성코드 배포 등의 공격을 수행할 수 있다. 이 취약점은 인터넷 뱅킹 계정 탈취, 기업 인트라넷 공격 등 심각한 피해를 유발한다. 설계 단계에서 모든 외부 입력값을 출력 컨텍스트(HTML, JS, URL, CSS)에 맞게 인코딩하는 정책을 의무화해야 한다.",
        "guideRef": "PART3 제1절 5항 (p.77-82)",
        "bad_code": "// ❌ 외부 입력값을 HTML에 직접 출력 (XSS)\nout.println(\"<p>안녕하세요, \" + request.getParameter(\"name\") + \"</p>\");",
        "good_code": "// ✅ HTML 인코딩 후 출력\nString name = request.getParameter(\"name\");\nString safe = name.replace(\"&\", \"&amp;\").replace(\"<\", \"&lt;\")\n                  .replace(\">\", \"&gt;\").replace(\"\\\"\", \"&quot;\")\n                  .replace(\"'\", \"&#x27;\");\nout.println(\"<p>안녕하세요, \" + safe + \"</p>\");\n// 또는 OWASP Java Encoder: Encode.forHtml(name)",
        "reference_url": "https://cwe.mitre.org/data/definitions/79.html"
      }
    },
    {
      "ruleId": "DS-1.6",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "웹 기반 중요 기능 수행 요청 유효성 검증",
      "cwe": [
        "CWE-352"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "CSRF 방지를 위한 토큰 생성 및 검증 메커니즘 설계",
      "relatedImplRules": [
        "IV-1.11"
      ],
      "dangerousPatterns": [
        "void doPost\\(|@PostMapping"
      ],
      "remediation": {
        "strategy": "CSRF_TOKEN",
        "description": "CSRF(Cross-Site Request Forgery) 취약점은 인증된 사용자의 세션을 이용해 공격자가 의도한 요청을 정상 사용자인 것처럼 서버에 전송할 수 있을 때 발생한다. 공격자는 악성 사이트에 숨겨진 폼이나 이미지 태그를 통해 피해자가 의도하지 않은 계좌이체·비밀번호 변경·게시물 삭제 등을 실행시킬 수 있다. 이는 별도의 악성코드 없이도 정상 사용자 권한으로 서버를 공격할 수 있어 매우 교묘한 취약점이다. 설계 단계에서 상태 변경 요청에 Synchronizer Token Pattern이나 SameSite 쿠키 속성을 의무화해야 한다.",
        "guideRef": "PART3 제1절 6항 (p.83-87)",
        "bad_code": "// ❌ CSRF 토큰 없이 상태 변경 요청 처리\n@PostMapping(\"/transfer\")\npublic String transfer(String toAccount, int amount, HttpSession session) {\n    accountService.transfer(session.getAttribute(\"userId\"), toAccount, amount);\n    return \"success\";\n}",
        "good_code": "// ✅ CSRF 토큰 검증\n@PostMapping(\"/transfer\")\npublic String transfer(String csrfToken, String toAccount, int amount,\n                       HttpSession session) {\n    String expected = (String) session.getAttribute(\"csrfToken\");\n    if (expected == null || !expected.equals(csrfToken)) {\n        throw new SecurityException(\"CSRF 토큰 불일치\");\n    }\n    accountService.transfer(session.getAttribute(\"userId\"), toAccount, amount);\n    return \"success\";\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/352.html"
      }
    },
    {
      "ruleId": "DS-1.7",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "HTTP 프로토콜 유효성 검증",
      "cwe": [
        "CWE-113"
      ],
      "severity": "MEDIUM",
      "phase": "DESIGN",
      "description": "HTTP 응답분할 방지를 위한 헤더 값 검증 설계",
      "relatedImplRules": [
        "IV-1.13"
      ],
      "dangerousPatterns": [
        "setHeader\\(|addHeader\\("
      ],
      "remediation": {
        "strategy": "CRLF_REMOVAL",
        "description": "HTTP 응답 헤더에 외부 입력값이 CR(\\r), LF(\\n) 문자 필터링 없이 포함되면 HTTP 응답분할(Response Splitting) 취약점이 발생한다. 공격자는 입력값에 CRLF 시퀀스를 삽입하여 하나의 HTTP 응답을 두 개로 분리하고, 임의의 헤더·쿠키·응답 본문을 주입할 수 있다. 이를 통해 XSS 공격, 캐시 포이즈닝, 세션 하이재킹 등의 2차 공격을 유발할 수 있다. 설계 단계에서 HTTP 헤더에 사용되는 모든 입력값에서 CR/LF 및 유사 제어 문자를 제거하도록 설계해야 한다.",
        "guideRef": "PART3 제1절 7항 (p.88-92)",
        "bad_code": "// ❌ 외부 입력값을 HTTP 헤더에 직접 삽입 (CRLF 삽입 가능)\nString lang = request.getParameter(\"lang\");\nresponse.setHeader(\"Content-Language\", lang);",
        "good_code": "// ✅ CR/LF 문자 제거 후 헤더에 설정\nString lang = request.getParameter(\"lang\");\nif (lang != null) {\n    lang = lang.replaceAll(\"[\\\\r\\\\n]\", \"\");\n    // 화이트리스트 검증 추가\n    if (lang.matches(\"[a-zA-Z\\\\-]{2,10}\")) {\n        response.setHeader(\"Content-Language\", lang);\n    }\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/113.html"
      }
    },
    {
      "ruleId": "DS-1.8",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "허용된 범위내 메모리 접근",
      "cwe": [
        "CWE-119",
        "CWE-190"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "버퍼 접근 범위 제한 및 정수 오버플로우 방지 설계",
      "relatedImplRules": [
        "IV-1.14",
        "IV-1.16"
      ],
      "dangerousPatterns": [
        "byte\\[\\]|System\\.arraycopy|ByteBuffer"
      ],
      "remediation": {
        "strategy": "BOUNDS_CHECK",
        "description": "배열·버퍼의 크기나 인덱스를 외부 입력값으로 결정할 때 범위 검사가 없으면 버퍼 오버플로우 및 정수 오버플로우 취약점이 발생한다. 공격자는 비정상적으로 큰 값이나 음수, 또는 오버플로우를 유발하는 값을 입력하여 메모리 손상, 서비스 거부, 잠재적인 코드 실행을 시도할 수 있다. Java는 배열 경계 위반 시 예외를 발생시키지만, 정수 오버플로우로 인한 음수·0 크기 배열 생성은 논리적 취약점으로 이어진다. 설계 단계에서 외부 입력 정수값에 대해 허용 범위 검증과 Math.addExact/multiplyExact 같은 안전한 연산을 적용하도록 설계해야 한다.",
        "guideRef": "PART3 제1절 8항 (p.93-98)",
        "bad_code": "// ❌ 정수형 오버플로우로 잘못된 배열 크기 산출\nint size = width * height;   // width=65536, height=65536 → 오버플로우 → 0\nbyte[] buf = new byte[size]; // 의도하지 않은 크기",
        "good_code": "// ✅ 경계 검사 후 안전하게 연산\nif (width <= 0 || height <= 0 || width > 10000 || height > 10000) {\n    throw new IllegalArgumentException(\"허용 범위 초과: \" + width + \"x\" + height);\n}\nlong size = (long) width * height;\nif (size > Integer.MAX_VALUE) {\n    throw new IllegalArgumentException(\"버퍼 크기 초과\");\n}\nbyte[] buf = new byte[(int) size];",
        "reference_url": "https://cwe.mitre.org/data/definitions/119.html"
      }
    },
    {
      "ruleId": "DS-1.9",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "보안기능 입력값 검증",
      "cwe": [
        "CWE-807",
        "CWE-476"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "보안결정에 사용되는 입력값 검증 로직 설계",
      "relatedImplRules": [
        "IV-1.15"
      ],
      "dangerousPatterns": [
        "getParameter.*role|getParameter.*admin|getParameter.*permission"
      ],
      "remediation": {
        "strategy": "SERVER_SIDE_AUTH_CHECK",
        "description": "보안 결정(인증, 권한 부여)에 클라이언트에서 전달된 파라미터(role, isAdmin 등)를 그대로 사용하면 보안 우회 취약점이 발생한다. 공격자는 HTTP 파라미터·숨겨진 폼 필드·쿠키 값을 조작하여 관리자 권한을 획득하거나 접근 제한 기능을 우회할 수 있다. 이는 시스템 전체 권한 탈취, 타인 데이터 무단 접근·변조 등 심각한 피해로 이어진다. 설계 단계에서 보안 결정은 반드시 서버 측 세션이나 SecurityContext의 데이터만 사용하고 클라이언트 입력값을 신뢰하지 않도록 설계해야 한다.",
        "guideRef": "PART3 제1절 9항 (p.99-103)",
        "bad_code": "// ❌ 클라이언트 파라미터로 보안 결정 (우회 가능)\nString role = request.getParameter(\"role\"); // 공격자가 \"admin\" 전달 가능\nif (\"admin\".equals(role)) {\n    showAdminPage(response);\n}",
        "good_code": "// ✅ 서버 세션 기반 보안 결정\nHttpSession session = request.getSession(false);\nif (session == null) {\n    response.sendRedirect(\"/login\");\n    return;\n}\nString role = (String) session.getAttribute(\"role\");\nif (\"admin\".equals(role)) {\n    showAdminPage(response);\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/807.html"
      }
    },
    {
      "ruleId": "DS-1.10",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "업로드·다운로드 파일 검증",
      "cwe": [
        "CWE-434",
        "CWE-494"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "업로드 파일 유형·크기 검증 및 다운로드 경로 검증 설계",
      "relatedImplRules": [
        "IV-1.6"
      ],
      "dangerousPatterns": [
        "getOriginalFilename\\(\\)|getPart\\(|transferTo\\("
      ],
      "remediation": {
        "strategy": "FILE_EXTENSION_WHITELIST",
        "description": "파일 업로드 시 파일 유형·크기·저장 경로를 검증하지 않으면 위험한 파일 업로드 취약점이 발생한다. 공격자는 웹 셸(.jsp, .php 등)을 업로드하거나, '../' 경로 조작으로 임의 위치에 파일을 저장하거나, 대용량 파일로 서비스 거부 공격을 수행할 수 있다. 업로드된 웹 셸이 실행되면 서버 전체를 장악할 수 있어 CRITICAL 수준의 피해가 발생한다. 설계 단계에서 확장자 화이트리스트 검증, 저장 경로의 웹 루트 외부 설정, 파일명 랜덤화를 의무화해야 한다.",
        "guideRef": "PART3 제1절 10항 (p.104-110)",
        "bad_code": "// ❌ 파일 확장자·Content-Type 검증 없이 업로드 허용\nString fileName = item.getName();\nFile dest = new File(uploadDir, fileName);\nitem.write(dest); // .jsp, .php 등 실행 파일 업로드 가능",
        "good_code": "// ✅ 화이트리스트 확장자 검증 + 저장명 랜덤화\nSet<String> allowed = new HashSet<>(Arrays.asList(\"jpg\", \"png\", \"pdf\"));\nString origName = item.getName();\nString ext = origName.substring(origName.lastIndexOf('.') + 1).toLowerCase();\nif (!allowed.contains(ext)) {\n    throw new SecurityException(\"허용되지 않는 파일 형식: \" + ext);\n}\nString safeName = UUID.randomUUID().toString() + \".\" + ext;\nitem.write(new File(uploadDir, safeName));",
        "reference_url": "https://cwe.mitre.org/data/definitions/434.html"
      }
    },
    {
      "ruleId": "DS-2.1",
      "part": "PART3",
      "section": "보안기능",
      "name": "인증 대상 및 방식",
      "cwe": [
        "CWE-306"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "중요 기능에 대한 적절한 인증 수단 적용 설계",
      "relatedImplRules": [
        "IV-2.1"
      ],
      "dangerousPatterns": [
        "HttpSession|getSession\\(|session\\.getAttribute"
      ],
      "remediation": {
        "strategy": "AUTH_GATE_FILTER",
        "description": "중요 기능에 적절한 인증 메커니즘이 적용되지 않으면 인증 우회 취약점이 발생한다. 공격자는 인증 없이 중요 기능 URL에 직접 접근하거나, 인증 로직이 누락된 서블릿·엔드포인트를 통해 무단으로 시스템 기능을 사용할 수 있다. 이는 개인정보 무단 조회·변조, 관리자 기능 무단 사용, 금융 거래 조작 등의 피해를 유발한다. 설계 단계에서 중요 기능 접근 전 인증 필터(AuthFilter)를 일괄 적용하는 구조를 의무화해야 한다.",
        "guideRef": "PART3 제2절 1항 (p.113-118)",
        "bad_code": "// ❌ 인증 없이 중요 기능 접근 허용\n@GetMapping(\"/admin/users\")\npublic List<User> listUsers() {\n    return userService.findAll(); // 로그인 여부 미확인\n}",
        "good_code": "// ✅ 인증 필터 또는 어노테이션으로 접근 통제\n// Spring Security 사용 시:\n@GetMapping(\"/admin/users\")\n@PreAuthorize(\"hasRole('ADMIN')\")\npublic List<User> listUsers() {\n    return userService.findAll();\n}\n// 또는 직접 세션 확인:\nHttpSession session = request.getSession(false);\nif (session == null || session.getAttribute(\"userId\") == null) {\n    response.sendError(HttpServletResponse.SC_UNAUTHORIZED);\n    return;\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/306.html"
      }
    },
    {
      "ruleId": "DS-2.2",
      "part": "PART3",
      "section": "보안기능",
      "name": "인증 수행 제한",
      "cwe": [
        "CWE-307"
      ],
      "severity": "MEDIUM",
      "phase": "DESIGN",
      "description": "반복 인증 시도 제한(계정 잠금) 메커니즘 설계",
      "relatedImplRules": [
        "IV-2.16"
      ],
      "dangerousPatterns": [
        "loginAttempt|failCount|lockAccount|attemptCount"
      ],
      "remediation": {
        "strategy": "ACCOUNT_LOCKOUT",
        "description": "로그인 시도 횟수에 제한이 없으면 무차별 대입(Brute Force) 공격에 취약해진다. 공격자는 자동화 도구로 수백만 번의 비밀번호 조합을 시도하여 계정을 탈취할 수 있으며, 특히 짧거나 단순한 비밀번호 계정은 단시간에 공략된다. 탈취된 계정으로 개인정보 유출, 금융 사기, 내부 시스템 침투 등의 2차 피해가 발생할 수 있다. 설계 단계에서 연속 실패 횟수 임계값 설정, 계정 잠금 또는 CAPTCHA 메커니즘을 의무화해야 한다.",
        "guideRef": "PART3 제2절 2항 (p.119-123)",
        "bad_code": "// ❌ 로그인 시도 횟수 제한 없음 (무차별 대입 허용)\npublic boolean login(String id, String pw) {\n    return userDao.checkPassword(id, pw); // 실패 횟수 미추적\n}",
        "good_code": "// ✅ 5회 실패 시 계정 잠금 (30분)\npublic boolean login(String id, String pw) {\n    int failCount = loginAttemptCache.getOrDefault(id, 0);\n    if (failCount >= 5) {\n        throw new LockedException(\"계정이 잠겼습니다. 30분 후 재시도하세요.\");\n    }\n    if (!userDao.checkPassword(id, pw)) {\n        loginAttemptCache.put(id, failCount + 1);\n        return false;\n    }\n    loginAttemptCache.remove(id);\n    return true;\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/307.html"
      }
    },
    {
      "ruleId": "DS-2.3",
      "part": "PART3",
      "section": "보안기능",
      "name": "비밀번호 관리",
      "cwe": [
        "CWE-521"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "비밀번호 복잡성 정책 및 안전한 저장 방식 설계",
      "relatedImplRules": [
        "IV-2.9"
      ],
      "dangerousPatterns": [
        "password\\s*=\\s*\"|setPassword\\("
      ],
      "remediation": {
        "strategy": "PASSWORD_POLICY",
        "description": "비밀번호 복잡성 정책이 없거나 평문·약한 해시로 저장하면 비밀번호 관리 취약점이 발생한다. 공격자는 단순 비밀번호를 사전 공격으로 쉽게 추측하거나, 솔트 없는 MD5/SHA-1 해시를 레인보우 테이블로 역산하여 대량 계정을 탈취할 수 있다. 유출된 비밀번호는 동일 비밀번호를 사용하는 다른 서비스에서도 악용되는 크리덴셜 스터핑 공격으로 이어진다. 설계 단계에서 8자 이상·대소문자·숫자·특수문자 조합 정책과 bcrypt/PBKDF2 기반 안전한 저장 방식을 의무화해야 한다.",
        "guideRef": "PART3 제2절 3항 (p.124-130)",
        "bad_code": "// ❌ 비밀번호 복잡도 검증 없이 저장\npublic void changePassword(String newPw) {\n    userDao.updatePassword(userId, newPw); // \"1234\" 같은 단순 비밀번호 허용\n}",
        "good_code": "// ✅ 복잡도 정책 적용: 8자 이상, 영문+숫자+특수문자 포함\npublic void changePassword(String newPw) {\n    if (newPw == null || newPw.length() < 8) {\n        throw new IllegalArgumentException(\"비밀번호는 8자 이상이어야 합니다.\");\n    }\n    boolean hasLetter  = newPw.matches(\".*[a-zA-Z].*\");\n    boolean hasDigit   = newPw.matches(\".*\\\\d.*\");\n    boolean hasSpecial = newPw.matches(\".*[!@#$%^&*].*\");\n    if (!hasLetter || !hasDigit || !hasSpecial) {\n        throw new IllegalArgumentException(\"영문·숫자·특수문자를 모두 포함해야 합니다.\");\n    }\n    userDao.updatePassword(userId, hash(newPw));\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/521.html"
      }
    },
    {
      "ruleId": "DS-2.4",
      "part": "PART3",
      "section": "보안기능",
      "name": "중요자원 접근통제",
      "cwe": [
        "CWE-285",
        "CWE-732"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "중요 자원에 대한 접근권한 최소화 및 통제 설계",
      "relatedImplRules": [
        "IV-2.2",
        "IV-2.3"
      ],
      "dangerousPatterns": [
        "setReadable\\(|setWritable\\(|PosixFilePermissions"
      ],
      "remediation": {
        "strategy": "LEAST_PRIVILEGE",
        "description": "중요 자원(파일, DB, API)에 과도한 접근 권한을 부여하거나 자원 소유권 검증 없이 접근을 허용하면 권한 상승 취약점이 발생한다. 공격자는 다른 사용자의 자원 ID를 추측하거나, 인증만 확인하고 인가를 생략한 엔드포인트를 통해 타인의 데이터에 무단 접근할 수 있다. 이는 개인정보 대량 유출(IDOR 취약점), 기밀 파일 탈취, 시스템 설정 변경 등의 피해로 이어진다. 설계 단계에서 최소 권한 원칙(Least Privilege)을 적용하고, 자원 접근 시 소유자 또는 권한을 반드시 검증하도록 설계해야 한다.",
        "guideRef": "PART3 제2절 4항 (p.131-137)",
        "bad_code": "// ❌ 로그인 여부만 확인, 자원 소유권 미검증\n@GetMapping(\"/document/{id}\")\npublic Document getDoc(@PathVariable Long id, HttpSession session) {\n    if (session.getAttribute(\"userId\") == null) throw new UnauthorizedException();\n    return docService.findById(id); // 타인 문서 접근 가능\n}",
        "good_code": "// ✅ 자원 소유자 또는 권한 확인\n@GetMapping(\"/document/{id}\")\npublic Document getDoc(@PathVariable Long id, HttpSession session) {\n    Long userId = (Long) session.getAttribute(\"userId\");\n    if (userId == null) throw new UnauthorizedException();\n    Document doc = docService.findById(id);\n    if (!doc.getOwnerId().equals(userId)) {\n        throw new ForbiddenException(\"접근 권한이 없습니다.\");\n    }\n    return doc;\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/285.html"
      }
    },
    {
      "ruleId": "DS-2.5",
      "part": "PART3",
      "section": "보안기능",
      "name": "암호키 관리",
      "cwe": [
        "CWE-321"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "암호키 생성·저장·폐기 생명주기 관리 설계",
      "relatedImplRules": [
        "IV-2.6"
      ],
      "dangerousPatterns": [
        "KeyGenerator\\.getInstance|new SecretKeySpec|KeyStore\\.getInstance"
      ],
      "remediation": {
        "strategy": "EXTERNALIZE_SECRETS",
        "description": "암호키를 소스코드에 하드코딩하거나 안전하지 않은 위치에 저장하면 암호키 유출 취약점이 발생한다. 공격자가 소스코드, Git 히스토리, 또는 설정 파일에 접근하면 암호키를 획득하여 암호화된 모든 데이터를 복호화할 수 있다. 이는 DB 전체 개인정보 복호화, 통신 데이터 도청, 디지털 서명 위조 등 치명적인 결과를 초래한다. 설계 단계에서 암호키를 환경변수, Java KeyStore, 또는 HashiCorp Vault/AWS Secrets Manager 같은 외부 키 관리 시스템에서 로드하도록 설계해야 한다.",
        "guideRef": "PART3 제2절 5항 (p.138-144)",
        "bad_code": "// ❌ 소스코드에 암호키 하드코딩\nprivate static final String SECRET_KEY = \"myHardCodedKey123!\";\nSecretKeySpec keySpec = new SecretKeySpec(SECRET_KEY.getBytes(), \"AES\");",
        "good_code": "// ✅ 환경변수 또는 외부 키 저장소에서 키 로드\nString keyVal = System.getenv(\"APP_SECRET_KEY\");\nif (keyVal == null || keyVal.length() < 32) {\n    throw new IllegalStateException(\"암호키 환경변수(APP_SECRET_KEY) 미설정\");\n}\nSecretKeySpec keySpec = new SecretKeySpec(keyVal.getBytes(\"UTF-8\"), \"AES\");\n// 운영환경: AWS Secrets Manager / HashiCorp Vault 활용 권장",
        "reference_url": "https://cwe.mitre.org/data/definitions/321.html"
      }
    },
    {
      "ruleId": "DS-2.6",
      "part": "PART3",
      "section": "보안기능",
      "name": "암호연산",
      "cwe": [
        "CWE-327",
        "CWE-326"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "안전한 암호 알고리즘 및 충분한 키 길이 사용 설계",
      "relatedImplRules": [
        "IV-2.4",
        "IV-2.7"
      ],
      "dangerousPatterns": [
        "Cipher\\.getInstance|MessageDigest\\.getInstance"
      ],
      "remediation": {
        "strategy": "STRONG_CRYPTO",
        "description": "DES, RC4, MD5, SHA-1 등 취약하거나 폐기된 암호 알고리즘을 사용하면 암호화 취약점이 발생한다. 현대의 컴퓨팅 파워로 DES는 수 시간 내에, MD5/SHA-1 해시는 레인보우 테이블이나 GPU 가속으로 짧은 시간에 공략할 수 있다. 이를 통해 암호화된 개인정보·금융정보·비밀번호가 노출되거나 디지털 서명이 위조될 수 있다. 설계 단계에서 대칭 암호화는 AES-256-GCM, 해시는 SHA-256 이상, 비대칭 암호화는 RSA-2048 이상의 안전한 알고리즘만 허용하도록 설계해야 한다.",
        "guideRef": "PART3 제2절 6항 (p.145-152)",
        "bad_code": "// ❌ 취약한 암호 알고리즘 사용 (DES, MD5)\nCipher cipher = Cipher.getInstance(\"DES\");\nMessageDigest md = MessageDigest.getInstance(\"MD5\");\nbyte[] hash = md.digest(password.getBytes());",
        "good_code": "// ✅ 안전한 알고리즘 사용 (AES-256, SHA-256)\nCipher cipher = Cipher.getInstance(\"AES/GCM/NoPadding\");\nGCMParameterSpec spec = new GCMParameterSpec(128, iv);\ncipher.init(Cipher.ENCRYPT_MODE, secretKey, spec);\n// 패스워드 해시: PBKDF2 사용\nSecretKeyFactory skf = SecretKeyFactory.getInstance(\"PBKDF2WithHmacSHA256\");\nKeySpec ks = new PBEKeySpec(password.toCharArray(), salt, 310000, 256);\nbyte[] hash = skf.generateSecret(ks).getEncoded();",
        "reference_url": "https://cwe.mitre.org/data/definitions/327.html"
      }
    },
    {
      "ruleId": "DS-2.7",
      "part": "PART3",
      "section": "보안기능",
      "name": "중요정보 저장",
      "cwe": [
        "CWE-312",
        "CWE-539"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "중요정보 암호화 저장 및 쿠키 보안 속성 설계",
      "relatedImplRules": [
        "IV-2.5",
        "IV-2.12"
      ],
      "dangerousPatterns": [
