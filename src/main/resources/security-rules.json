      "taintAnalysis": false,
      "sources": [],
      "sinks": [],
      "sanitizers": [],
      "remediation": {
        "strategy": "SAFE_ARRAY_ACCESS",
        "description": "배열·버퍼 접근 전 경계값 검사, Java의 경우 NIO Buffer API 활용",
        "guideRef": "PART4 제1절 16항 (p.303-308)",
        "remediationCode": "// [수정] IV-1.16 버퍼 오버플로우 방지: 경계 검사 + NIO Buffer API\n// ❌ 취약: 외부 입력값으로 배열 크기·인덱스 지정\nint size = Integer.parseInt(request.getParameter(\"size\"));\nbyte[] buf = new byte[size];  // 음수/대용량 가능\n\n// ✅ 안전: 범위 검사 후 NIO Buffer API 사용\nint size = Integer.parseInt(request.getParameter(\"size\"));\nif (size <= 0 || size > 65536)\n    throw new IllegalArgumentException(\"크기 범위 초과: \" + size);\nByteBuffer buf = ByteBuffer.allocate(size);\n// System.arraycopy 범위 검사\nif (length < 0 || srcOff < 0 || srcOff + length > src.length)\n    throw new ArrayIndexOutOfBoundsException(\"복사 범위 초과\");\nbyte[] copy = Arrays.copyOfRange(src, srcOff, srcOff + length);"
      },
      "dangerousPatterns": [
        "System\\.arraycopy\\(|byte\\[\\].*=.*new byte|ByteBuffer\\.allocate"
      ],
      "codeExamples": {
        "bad": "// ❌ 경계 검사 없이 배열 접근 (버퍼 오버플로우)\nbyte[] buf = new byte[64];\nint len = Integer.parseInt(request.getParameter(\"len\"));\nSystem.arraycopy(srcData, 0, buf, 0, len); // len > 64 시 예외",
        "good": "// ✅ 배열 크기 범위 내로 복사 길이 제한\nbyte[] buf = new byte[64];\nint len = Integer.parseInt(request.getParameter(\"len\"));\nif (len < 0 || len > buf.length || len > srcData.length) {\n    throw new IllegalArgumentException(\"복사 길이 범위 초과: \" + len);\n}\nSystem.arraycopy(srcData, 0, buf, 0, len);"
      }
    },
