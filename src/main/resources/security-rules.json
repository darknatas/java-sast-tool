      "name": "인증 대상 및 방식",
      "cwe": [
        "CWE-306"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "중요 기능에 대한 적절한 인증 수단 적용 설계",
      "relatedImplRules": [
        "IV-2.1"
      ],
      "dangerousPatterns": [
        "HttpSession|getSession\\(|session\\.getAttribute"
      ],
      "remediation": {
        "strategy": "AUTH_GATE_FILTER",
        "description": "중요 기능에 대한 적절한 인증 수단 적용 설계",
        "guideRef": "PART3 제2절 1항 (p.113-118)",
        "remediationCode": "// [수정] DS-2.1 인증 설계: AuthFilter로 중요 기능 일괄 인증 검사\n// ❌ 취약: 각 서블릿에 인증 로직 산발 배치 (누락 위험)\n// class OrderServlet { doGet() { /* 인증 없음 */ } }\n// ✅ 안전: AuthFilter로 일괄 적용\n@WebFilter(\"/*\")\npublic class AuthFilter implements Filter {\n    private static final Set<String> PUBLIC =\n        Set.of(\"/login\", \"/css/\", \"/js/\", \"/api/health\");\n    public void doFilter(ServletRequest req, ...) {\n        String path = ((HttpServletRequest) req).getRequestURI();\n        boolean pub = PUBLIC.stream().anyMatch(path::startsWith);\n        HttpSession ses = ((HttpServletRequest)req).getSession(false);\n        if (!pub && (ses == null ||\n                ses.getAttribute(\"loginUser\") == null)) {\n            ((HttpServletResponse)res).sendRedirect(\"/login\");\n            return;\n        }\n        chain.doFilter(req, res);\n    }\n}"
      },
      "codeExamples": {
        "bad": "// ❌ 인증 없이 중요 기능 접근 허용\n@GetMapping(\"/admin/users\")\npublic List<User> listUsers() {\n    return userService.findAll(); // 로그인 여부 미확인\n}",
        "good": "// ✅ 인증 필터 또는 어노테이션으로 접근 통제\n// Spring Security 사용 시:\n@GetMapping(\"/admin/users\")\n@PreAuthorize(\"hasRole('ADMIN')\")\npublic List<User> listUsers() {\n    return userService.findAll();\n}\n// 또는 직접 세션 확인:\nHttpSession session = request.getSession(false);\nif (session == null || session.getAttribute(\"userId\") == null) {\n    response.sendError(HttpServletResponse.SC_UNAUTHORIZED);\n    return;\n}"
      }
    },
    {
      "ruleId": "DS-2.2",
      "part": "PART3",
      "section": "보안기능",
      "name": "인증 수행 제한",
      "cwe": [
        "CWE-307"
      ],
      "severity": "MEDIUM",
      "phase": "DESIGN",
      "description": "반복 인증 시도 제한(계정 잠금) 메커니즘 설계",
      "relatedImplRules": [
        "IV-2.16"
      ],
      "dangerousPatterns": [
        "loginAttempt|failCount|lockAccount|attemptCount"
      ],
      "remediation": {
        "strategy": "ACCOUNT_LOCKOUT",
        "description": "반복 인증 시도 제한(계정 잠금) 메커니즘 설계",
        "guideRef": "PART3 제2절 2항 (p.119-123)",
        "remediationCode": "// [수정] DS-2.2 인증 시도 제한 설계: 계정 잠금 메커니즘\n// ❌ 취약: 실패 횟수 제한 없음 — if(!login()) return \"실패\";\n// ✅ 안전: 실패 횟수 추적 + 잠금\nMap<String, Integer> failMap = new ConcurrentHashMap<>();\nMap<String, Long> lockMap   = new ConcurrentHashMap<>();\nfinal int MAX = 5;\nfinal long LOCK_MS = 30 * 60 * 1000L;\nLong lockedUntil = lockMap.get(userId);\nif (lockedUntil != null && System.currentTimeMillis() < lockedUntil)\n    throw new AccountLockedException(\"계정 잠김 (30분 후 재시도)\");\nif (!authService.login(userId, password)) {\n    int fails = failMap.merge(userId, 1, Integer::sum);\n    if (fails >= MAX) {\n        lockMap.put(userId, System.currentTimeMillis() + LOCK_MS);\n        failMap.remove(userId);\n        throw new AccountLockedException(\"5회 실패 — 30분 잠금\");\n    }\n    throw new AuthException(\"실패 (\" + fails + \"/\" + MAX + \")\");\n}\nfailMap.remove(userId);"
      },
      "codeExamples": {
        "bad": "// ❌ 로그인 시도 횟수 제한 없음 (무차별 대입 허용)\npublic boolean login(String id, String pw) {\n    return userDao.checkPassword(id, pw); // 실패 횟수 미추적\n}",
        "good": "// ✅ 5회 실패 시 계정 잠금 (30분)\npublic boolean login(String id, String pw) {\n    int failCount = loginAttemptCache.getOrDefault(id, 0);\n    if (failCount >= 5) {\n        throw new LockedException(\"계정이 잠겼습니다. 30분 후 재시도하세요.\");\n    }\n    if (!userDao.checkPassword(id, pw)) {\n        loginAttemptCache.put(id, failCount + 1);\n        return false;\n    }\n    loginAttemptCache.remove(id);\n    return true;\n}"
      }
    },
    {
      "ruleId": "DS-2.3",
      "part": "PART3",
      "section": "보안기능",
      "name": "비밀번호 관리",
      "cwe": [
        "CWE-521"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "비밀번호 복잡성 정책 및 안전한 저장 방식 설계",
      "relatedImplRules": [
        "IV-2.9"
      ],
      "dangerousPatterns": [
        "password\\s*=\\s*\"|setPassword\\("
      ],
      "remediation": {
        "strategy": "PASSWORD_POLICY",
        "description": "비밀번호 복잡성 정책 및 안전한 저장 방식 설계",
        "guideRef": "PART3 제2절 3항 (p.124-130)",
        "remediationCode": "// [수정] DS-2.3 비밀번호 관리 설계: 복잡성 정책 + 안전한 저장\n// ❌ 취약: 비밀번호 평문 저장 또는 단순 MD5\nString hash = DigestUtils.md5Hex(password);  // 레인보우 테이블 취약\n\n// ✅ 안전: 복잡성 검증 + BCrypt/PBKDF2 저장\n// [복잡성 정책]\nPattern PW = Pattern.compile(\n    \"^(?=.*[A-Z])(?=.*[a-z])(?=.*[0-9])(?=.*[!@#$%^&*]).{8,20}$\");\nif (!PW.matcher(password).matches())\n    throw new ValidationException(\n        \"8~20자, 대/소문자·숫자·특수문자 포함 필수\");\n// [BCrypt 해시 저장 — Spring Security]\nBCryptPasswordEncoder enc = new BCryptPasswordEncoder(12);\nString stored = enc.encode(password);   // 솔트 자동 포함\n// [검증]\nboolean ok = enc.matches(rawPassword, stored);"
      },
      "codeExamples": {
        "bad": "// ❌ 비밀번호 복잡도 검증 없이 저장\npublic void changePassword(String newPw) {\n    userDao.updatePassword(userId, newPw); // \"1234\" 같은 단순 비밀번호 허용\n}",
        "good": "// ✅ 복잡도 정책 적용: 8자 이상, 영문+숫자+특수문자 포함\npublic void changePassword(String newPw) {\n    if (newPw == null || newPw.length() < 8) {\n        throw new IllegalArgumentException(\"비밀번호는 8자 이상이어야 합니다.\");\n    }\n    boolean hasLetter  = newPw.matches(\".*[a-zA-Z].*\");\n    boolean hasDigit   = newPw.matches(\".*\\\\d.*\");\n    boolean hasSpecial = newPw.matches(\".*[!@#$%^&*].*\");\n    if (!hasLetter || !hasDigit || !hasSpecial) {\n        throw new IllegalArgumentException(\"영문·숫자·특수문자를 모두 포함해야 합니다.\");\n    }\n    userDao.updatePassword(userId, hash(newPw));\n}"
      }
    },
