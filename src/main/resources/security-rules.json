    {
      "ruleId": "IV-4.2",
      "part": "PART4",
      "section": "에러처리",
      "name": "오류상황 대응 부재",
      "cwe": [
        "CWE-390"
      ],
      "severity": "MEDIUM",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": false,
      "dangerousPatterns": [
        "catch\\s*\\(.*\\)\\s*\\{\\s*\\}"
