        "CWE-307"
      ],
      "severity": "MEDIUM",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": false,
      "remediation": {
        "strategy": "ACCOUNT_LOCKOUT",
        "description": "로그인 실패 횟수 임계값 설정 및 계정 잠금/CAPTCHA 메커니즘 구현",
        "guideRef": "PART4 제2절 16항 (p.400-405)",
        "remediationCode": "// [수정] IV-2.16 반복 인증 시도 제한: 계정 잠금 구현\n// ❌ 취약: 실패 횟수 제한 없음 — if(!login()) return \"실패\";\n// ✅ 안전: 실패 횟수 추적 + 잠금\nMap<String, Integer> failMap = new ConcurrentHashMap<>();\nMap<String, Long> lockMap   = new ConcurrentHashMap<>();\nfinal int MAX = 5;\nfinal long LOCK_MS = 30 * 60 * 1000L;\nLong lockedUntil = lockMap.get(userId);\nif (lockedUntil != null && System.currentTimeMillis() < lockedUntil)\n    throw new AccountLockedException(\"계정 잠김 (30분 후 재시도)\");\nif (!authService.login(userId, password)) {\n    int fails = failMap.merge(userId, 1, Integer::sum);\n    if (fails >= MAX) {\n        lockMap.put(userId, System.currentTimeMillis() + LOCK_MS);\n        failMap.remove(userId);\n        throw new AccountLockedException(\"5회 실패 — 30분 잠금\");\n    }\n    throw new AuthException(\"실패 (\" + fails + \"/\" + MAX + \")\");\n}\nfailMap.remove(userId);"
      },
      "dangerousPatterns": [
        "authenticate\\(|checkLogin\\(|verifyPassword\\("
      ],
      "codeExamples": {
        "bad": "// ❌ 로그인 실패 횟수 제한 없음 (무차별 대입 허용)\npublic boolean login(String id, String pw) {\n    return userDao.checkPassword(id, pw);\n}",
        "good": "// ✅ 5회 실패 시 계정 30분 잠금\nprivate final Map<String, Integer> failMap = new ConcurrentHashMap<>();\nprivate final Map<String, Long>    lockMap = new ConcurrentHashMap<>();\npublic boolean login(String id, String pw) {\n    Long lockedUntil = lockMap.get(id);\n    if (lockedUntil != null && System.currentTimeMillis() < lockedUntil) {\n        throw new LockedException(\"계정 잠금 중\");\n    }\n    if (!userDao.checkPassword(id, pw)) {\n        int cnt = failMap.merge(id, 1, Integer::sum);\n        if (cnt >= 5) lockMap.put(id, System.currentTimeMillis() + 1800_000L);\n        return false;\n    }\n    failMap.remove(id); lockMap.remove(id);\n    return true;\n}"
      }
