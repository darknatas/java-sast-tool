      "remediation": {
        "strategy": "ENCRYPT_SENSITIVE_DATA",
        "description": "중요정보 암호화 저장 및 쿠키 보안 속성 설계",
        "guideRef": "PART3 제2절 7항 (p.153-159)",
        "remediationCode": "// [수정] DS-2.7 중요정보 저장 설계: 암호화 저장 + 쿠키 보안\n// ❌ 취약: 중요정보 평문 쿠키 저장\nCookie c = new Cookie(\"userId\", userId);\nresponse.addCookie(c);\n\n// ✅ 안전: HttpOnly·Secure·SameSite 속성 + 중요정보 제거\nCookie c = new Cookie(\"SESSIONID\", session.getId());\nc.setHttpOnly(true);    // JS 접근 차단\nc.setSecure(true);      // HTTPS 전용\nc.setPath(\"/\");\nc.setMaxAge(-1);        // 세션 쿠키\n// SameSite 설정 (Set-Cookie 헤더 직접)\nresponse.addHeader(\"Set-Cookie\",\n    \"SESSIONID=\" + session.getId() +\n    \"; HttpOnly; Secure; SameSite=Strict; Path=/\");\n// DB: 주민번호·카드번호 등은 AES-256 암호화 후 저장"
      },
      "codeExamples": {
        "bad": "// ❌ 중요 정보(비밀번호) 평문 저장\nuserDao.save(new User(id, password)); // password를 그대로 DB에 저장",
        "good": "// ✅ PBKDF2 + Salt 해시 저장\nbyte[] salt = new byte[16];\nnew SecureRandom().nextBytes(salt);\nSecretKeyFactory skf = SecretKeyFactory.getInstance(\"PBKDF2WithHmacSHA256\");\nKeySpec ks = new PBEKeySpec(password.toCharArray(), salt, 310000, 256);\nbyte[] hash = skf.generateSecret(ks).getEncoded();\nString encoded = Base64.getEncoder().encodeToString(salt)\n                 + \":\" + Base64.getEncoder().encodeToString(hash);\nuserDao.save(new User(id, encoded));"
      }
    },
