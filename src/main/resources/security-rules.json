// security-rules.json — 행정안전부 소프트웨어 보안약점 진단가이드 2021
// PART3 (DS-x.x): 설계단계 20개 항목 | PART4 (IV-x.x): 구현단계 49개 항목
{
  "version": "2021.1",
  "source": "소프트웨어 보안약점 진단가이드 (2021), 행정안전부",
  "rules": [
    {
      "ruleId": "DS-1.1",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "DBMS 조회 및 결과 검증",
      "cwe": [
        "CWE-89"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "SQL 질의문 내 입력값 유효성 검증 및 바인딩 방식 적용 설계",
      "relatedImplRules": [
        "IV-1.1"
      ],
      "dangerousPatterns": [
        "executeQuery\\(|executeUpdate\\(|Statement.*execute"
      ],
      "remediation": {
        "strategy": "USE_PREPARED_STATEMENT",
        "description": "SQL 질의문 내 입력값 유효성 검증 및 바인딩 방식 적용 설계",
        "guideRef": "PART3 제1절 1항 (p.47-55)",
        "remediationCode": "// [수정] DS-1.1 DBMS 조회 설계: PreparedStatement 바인딩 방식 의무화\n// ❌ 취약: SQL 문자열에 외부 입력값 직접 연결\nString sql = \"SELECT * FROM user WHERE id='\" + id + \"'\";\nStatement stmt = con.createStatement();\nResultSet rs = stmt.executeQuery(sql);\n\n// ✅ 안전: PreparedStatement 파라미터 바인딩\nString sql = \"SELECT * FROM user WHERE id = ?\";\ntry (PreparedStatement ps = con.prepareStatement(sql)) {\n    ps.setString(1, id);\n    try (ResultSet rs = ps.executeQuery()) {\n        while (rs.next()) { /* 처리 */ }\n    }\n}\n// MyBatis: WHERE id = #{id}  (${id} 사용 금지)"
      },
      "codeExamples": {
        "bad": "// ❌ SQL 문자열에 외부 입력값 직접 연결\nString sql = \"SELECT * FROM user WHERE id='\" + id + \"'\";\nStatement stmt = con.createStatement();\nResultSet rs = stmt.executeQuery(sql);",
        "good": "// ✅ PreparedStatement 파라미터 바인딩\nString sql = \"SELECT * FROM user WHERE id = ?\";\nPreparedStatement ps = con.prepareStatement(sql);\nps.setString(1, id);\nResultSet rs = ps.executeQuery();\n// MyBatis: WHERE id = #{id}  (${id} 사용 금지)"
      }
    },
    {
      "ruleId": "DS-1.2",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "XML 조회 및 결과 검증",
      "cwe": [
        "CWE-652",
        "CWE-643"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "XPath·XQuery 질의문에 사용되는 파라미터 필터링 또는 바인딩 설계",
      "relatedImplRules": [
        "IV-1.9",
        "IV-1.10"
      ],
      "dangerousPatterns": [
        "xpath\\.evaluate|XPath\\.compile|executeXPath"
      ],
      "remediation": {
        "strategy": "PARAMETERIZED_XPATH",
        "description": "XPath·XQuery 질의문에 사용되는 파라미터 필터링 또는 바인딩 설계",
        "guideRef": "PART3 제1절 2항 (p.56-62)",
        "remediationCode": "// [수정] DS-1.2 XML 조회 설계: XPath 변수 바인딩 사용\n// ❌ 취약: 외부 입력값을 XPath 표현식에 직접 삽입\nString expr = \"/users/user[name='\" + userName + \"']\";\nxpath.evaluate(expr, doc, XPathConstants.NODESET);\n\n// ✅ 안전: XPathVariableResolver로 변수 바인딩\nXPath xp = XPathFactory.newInstance().newXPath();\nxp.setXPathVariableResolver(qn ->\n    \"name\".equals(qn.getLocalPart()) ? userName : null);\nNodeList result = (NodeList) xp.evaluate(\n    \"/users/user[name=$name]\", doc, XPathConstants.NODESET);\n// 특수문자 필터링: userName.replaceAll(\"['\\\"\\[\\]*]\", \"\")"
      },
      "codeExamples": {
        "bad": "// ❌ 외부 입력값을 XPath 표현식에 직접 삽입\nString expr = \"/users/user[name='\" + userName + \"']\";\nNodeList nl = (NodeList) xpath.evaluate(expr, doc, XPathConstants.NODESET);",
        "good": "// ✅ 특수문자 제거 후 화이트리스트 검증\nString safe = userName.replaceAll(\"[^a-zA-Z0-9가-힣]\", \"\");\nif (!safe.matches(\"[a-zA-Z0-9가-힣]{1,50}\")) {\n    throw new IllegalArgumentException(\"허용되지 않은 입력값\");\n}\nString expr = \"/users/user[name='\" + safe + \"']\";\nNodeList nl = (NodeList) xpath.evaluate(expr, doc, XPathConstants.NODESET);"
      }
    },
    {
      "ruleId": "DS-1.3",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "디렉토리 서비스 조회 및 결과 검증",
      "cwe": [
        "CWE-90"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "LDAP 질의에 사용되는 입력값 필터링 설계",
      "relatedImplRules": [
        "IV-1.10"
      ],
      "dangerousPatterns": [
        "DirContext|InitialDirContext|\\.search\\("
      ],
      "remediation": {
        "strategy": "LDAP_ENCODING",
        "description": "LDAP 질의에 사용되는 입력값 필터링 설계",
        "guideRef": "PART3 제1절 3항 (p.63-68)",
        "remediationCode": "// [수정] DS-1.3 LDAP 조회 설계: 특수문자 인코딩 후 사용\n// ❌ 취약: 외부 입력값을 LDAP 필터에 직접 삽입\nString filter = \"(uid=\" + userId + \")\";\nctx.search(\"ou=people,dc=example,dc=com\", filter, null);\n\n// ✅ 안전: LDAP 특수문자 인코딩 (RFC 4515)\nprivate String encodeLdap(String input) {\n    return input.replace(\"\\\\\", \"\\\\5c\")\n                .replace(\"*\",  \"\\\\2a\")\n                .replace(\"(\",  \"\\\\28\")\n                .replace(\")\",  \"\\\\29\")\n                .replace(\"\\0\", \"\\\\00\");\n}\nString safeUid = encodeLdap(userId);\nString filter = \"(uid=\" + safeUid + \")\";\nctx.search(\"ou=people,dc=example,dc=com\", filter, null);"
      },
      "codeExamples": {
        "bad": "// ❌ 외부 입력값을 LDAP 필터에 직접 삽입\nString filter = \"(uid=\" + userName + \")\";\nNamingEnumeration<?> result = ctx.search(base, filter, controls);",
        "good": "// ✅ LDAP 특수문자 이스케이프 후 삽입\nString safe = userName.replaceAll(\"[\\\\*\\\\(\\\\)\\\\\\\\\\0]\", \"\");\nString filter = \"(uid=\" + safe + \")\";\nNamingEnumeration<?> result = ctx.search(base, filter, controls);\n// 또는 Spring Security LdapUtils.escapeLdapSearchFilter() 활용"
      }
    },
    {
      "ruleId": "DS-1.4",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "시스템 자원 접근 및 명령어 수행 입력값 검증",
      "cwe": [
        "CWE-78",
        "CWE-22",
        "CWE-99"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "파일 경로·OS 명령어에 사용되는 외부 입력값 검증 설계",
      "relatedImplRules": [
        "IV-1.3",
        "IV-1.5"
      ],
      "dangerousPatterns": [
        "Runtime\\.getRuntime\\(\\)\\.exec|new ProcessBuilder"
      ],
      "remediation": {
        "strategy": "AVOID_OS_COMMAND",
        "description": "파일 경로·OS 명령어에 사용되는 외부 입력값 검증 설계",
        "guideRef": "PART3 제1절 4항 (p.69-76)",
        "remediationCode": "// [수정] DS-1.4 시스템 자원 접근 설계: 화이트리스트 + 배열 인자 방식\n// ❌ 취약: 외부 입력값으로 OS 명령어 문자열 구성\nString cmd = \"convert \" + request.getParameter(\"file\");\nRuntime.getRuntime().exec(cmd);\n\n// ✅ 안전: 화이트리스트 검증 + ProcessBuilder 배열 방식\nString fileId = request.getParameter(\"fileId\");\nif (!fileId.matches(\"^[a-zA-Z0-9_-]{1,50}$\"))\n    throw new SecurityException(\"허용되지 않는 파일 ID\");\nProcessBuilder pb = new ProcessBuilder(\n    \"/usr/bin/convert\",\n    \"/secure/uploads/\" + fileId + \".jpg\",\n    \"-resize\", \"200x200\",\n    \"/secure/thumbs/\" + fileId + \"_thumb.jpg\");\npb.start().waitFor();\n// OS 명령어 대신 Java API 사용 권장: Files.copy(), Files.delete()"
      },
      "codeExamples": {
        "bad": "// ❌ 외부 입력값을 OS 명령어에 직접 삽입\nString cmd = \"cmd.exe /c ping \" + ipAddress;\nRuntime.getRuntime().exec(cmd);",
        "good": "// ✅ Java API 직접 사용 (OS 명령어 우회)\nInetAddress addr = InetAddress.getByName(ipAddress);\nboolean reachable = addr.isReachable(3000);\n// 불가피하게 exec() 사용 시: 화이트리스트 검증\nif (!ipAddress.matches(\"^\\\\d{1,3}(\\\\.\\\\d{1,3}){3}$\")) {\n    throw new IllegalArgumentException(\"잘못된 IP 주소\");\n}\nString[] cmd = {\"ping\", \"-c\", \"1\", ipAddress};\nRuntime.getRuntime().exec(cmd);"
      }
    },
    {
      "ruleId": "DS-1.5",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "웹 서비스 요청 및 결과 검증",
      "cwe": [
        "CWE-79"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "웹 서비스 응답 데이터 XSS 필터링 및 인코딩 설계",
      "relatedImplRules": [
        "IV-1.4"
      ],
      "dangerousPatterns": [
        "out\\.print\\(|response\\.getWriter"
      ],
      "remediation": {
        "strategy": "OUTPUT_ENCODING",
        "description": "웹 서비스 응답 데이터 XSS 필터링 및 인코딩 설계",
        "guideRef": "PART3 제1절 5항 (p.77-82)",
        "remediationCode": "// [수정] DS-1.5 웹 출력 설계: 컨텍스트별 출력 인코딩 의무화\n// ❌ 취약: 외부 입력값을 HTML에 그대로 출력\nString name = request.getParameter(\"name\");\nout.println(\"<div>안녕하세요, \" + name + \"님</div>\");\n\n// ✅ 안전 (HTML 컨텍스트): Spring HtmlUtils 또는 ESAPI 사용\nimport org.springframework.web.util.HtmlUtils;\nString safe = HtmlUtils.htmlEscape(name);\nout.println(\"<div>안녕하세요, \" + safe + \"님</div>\");\n\n// JSP: <c:out value=\"${name}\"/>  (EL 기본 인코딩)\n// JS 컨텍스트: ESAPI.encoder().encodeForJavaScript(name)\n// URL 파라미터: URLEncoder.encode(name, StandardCharsets.UTF_8)"
      },
      "codeExamples": {
        "bad": "// ❌ 외부 입력값을 HTML에 직접 출력 (XSS)\nout.println(\"<p>안녕하세요, \" + request.getParameter(\"name\") + \"</p>\");",
        "good": "// ✅ HTML 인코딩 후 출력\nString name = request.getParameter(\"name\");\nString safe = name.replace(\"&\", \"&amp;\").replace(\"<\", \"&lt;\")\n                  .replace(\">\", \"&gt;\").replace(\"\\\"\", \"&quot;\")\n                  .replace(\"'\", \"&#x27;\");\nout.println(\"<p>안녕하세요, \" + safe + \"</p>\");\n// 또는 OWASP Java Encoder: Encode.forHtml(name)"
      }
    },
    {
      "ruleId": "DS-1.6",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "웹 기반 중요 기능 수행 요청 유효성 검증",
      "cwe": [
        "CWE-352"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "CSRF 방지를 위한 토큰 생성 및 검증 메커니즘 설계",
      "relatedImplRules": [
        "IV-1.11"
      ],
      "dangerousPatterns": [
        "void doPost\\(|@PostMapping"
      ],
      "remediation": {
        "strategy": "CSRF_TOKEN",
        "description": "CSRF 방지를 위한 토큰 생성 및 검증 메커니즘 설계",
        "guideRef": "PART3 제1절 6항 (p.83-87)",
        "remediationCode": "// [수정] DS-1.6 CSRF 방지 설계: Synchronizer Token Pattern 적용\n// ❌ 취약: POST 요청에 CSRF 토큰 검증 없음\nprotected void doPost(HttpServletRequest req, ...) {\n    userService.delete(req.getParameter(\"userId\"));\n}\n\n// ✅ 안전: 토큰 생성(세션 저장) + 요청 시 검증\n// [로그인 성공 시 토큰 생성]\nbyte[] bytes = new byte[32];\nnew SecureRandom().nextBytes(bytes);\nString token = Base64.getUrlEncoder().withoutPadding()\n    .encodeToString(bytes);\nsession.setAttribute(\"_csrf\", token);\n// [POST 처리 시]\nString req = request.getParameter(\"_csrf\");\nString ses = (String) session.getAttribute(\"_csrf\");\nif (!MessageDigest.isEqual(req.getBytes(), ses.getBytes()))\n    throw new SecurityException(\"CSRF 토큰 불일치\");\n// Spring Security: @EnableWebSecurity 설정으로 자동 적용"
      },
      "codeExamples": {
        "bad": "// ❌ CSRF 토큰 없이 상태 변경 요청 처리\n@PostMapping(\"/transfer\")\npublic String transfer(String toAccount, int amount, HttpSession session) {\n    accountService.transfer(session.getAttribute(\"userId\"), toAccount, amount);\n    return \"success\";\n}",
        "good": "// ✅ CSRF 토큰 검증\n@PostMapping(\"/transfer\")\npublic String transfer(String csrfToken, String toAccount, int amount,\n                       HttpSession session) {\n    String expected = (String) session.getAttribute(\"csrfToken\");\n    if (expected == null || !expected.equals(csrfToken)) {\n        throw new SecurityException(\"CSRF 토큰 불일치\");\n    }\n    accountService.transfer(session.getAttribute(\"userId\"), toAccount, amount);\n    return \"success\";\n}"
      }
    },
    {
      "ruleId": "DS-1.7",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "HTTP 프로토콜 유효성 검증",
      "cwe": [
        "CWE-113"
      ],
      "severity": "MEDIUM",
      "phase": "DESIGN",
      "description": "HTTP 응답분할 방지를 위한 헤더 값 검증 설계",
      "relatedImplRules": [
        "IV-1.13"
      ],
      "dangerousPatterns": [
        "setHeader\\(|addHeader\\("
      ],
      "remediation": {
        "strategy": "CRLF_REMOVAL",
        "description": "HTTP 응답분할 방지를 위한 헤더 값 검증 설계",
        "guideRef": "PART3 제1절 7항 (p.88-92)",
        "remediationCode": "// [수정] DS-1.7 HTTP 헤더 검증 설계: CR/LF 문자 제거\n// ❌ 취약: 외부 입력값을 HTTP 헤더에 직접 삽입\nString lang = request.getParameter(\"lang\");\nresponse.setHeader(\"Content-Language\", lang);\n\n// ✅ 안전: CR(\\r)·LF(\\n) 및 유사 제어 문자 제거\nString lang = request.getParameter(\"lang\");\nif (lang != null) {\n    lang = lang.replaceAll(\"[\\\\r\\\\n\\\\u0085\\\\u2028\\\\u2029]\", \"\");\n    if (!lang.matches(\"^[a-zA-Z]{2,8}(-[a-zA-Z0-9]{2,8})*$\"))\n        lang = \"ko\";\n    response.setHeader(\"Content-Language\", lang);\n}\n// sendRedirect URL도 동일하게 CR/LF 제거 후 사용"
      },
      "codeExamples": {
        "bad": "// ❌ 외부 입력값을 HTTP 헤더에 직접 삽입 (CRLF 삽입 가능)\nString lang = request.getParameter(\"lang\");\nresponse.setHeader(\"Content-Language\", lang);",
        "good": "// ✅ CR/LF 문자 제거 후 헤더에 설정\nString lang = request.getParameter(\"lang\");\nif (lang != null) {\n    lang = lang.replaceAll(\"[\\\\r\\\\n]\", \"\");\n    // 화이트리스트 검증 추가\n    if (lang.matches(\"[a-zA-Z\\\\-]{2,10}\")) {\n        response.setHeader(\"Content-Language\", lang);\n    }\n}"
      }
    },
    {
      "ruleId": "DS-1.8",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "허용된 범위내 메모리 접근",
      "cwe": [
        "CWE-119",
        "CWE-190"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "버퍼 접근 범위 제한 및 정수 오버플로우 방지 설계",
      "relatedImplRules": [
        "IV-1.14",
        "IV-1.16"
      ],
      "dangerousPatterns": [
        "byte\\[\\]|System\\.arraycopy|ByteBuffer"
      ],
      "remediation": {
        "strategy": "BOUNDS_CHECK",
        "description": "버퍼 접근 범위 제한 및 정수 오버플로우 방지 설계",
        "guideRef": "PART3 제1절 8항 (p.93-98)",
        "remediationCode": "// [수정] DS-1.8 메모리 접근 설계: 정수 범위 검사 + 안전 연산\n// ❌ 취약: 입력값으로 배열 크기/인덱스를 직접 사용\nint size = Integer.parseInt(request.getParameter(\"size\"));\nbyte[] buf = new byte[size];  // 음수/대용량 가능\n\n// ✅ 안전: 범위 제한 검사\nint size = Integer.parseInt(request.getParameter(\"size\"));\nif (size < 1 || size > 1024 * 1024)\n    throw new IllegalArgumentException(\"허용 범위 초과 (1~1MB)\");\nbyte[] buf = new byte[size];\n\n// 정수 오버플로우 방지: Math.addExact / multiplyExact\nint a = Integer.parseInt(request.getParameter(\"a\"));\nint b = Integer.parseInt(request.getParameter(\"b\"));\ntry {\n    int sum = Math.addExact(a, b);\n} catch (ArithmeticException e) {\n    throw new IllegalArgumentException(\"계산 결과가 범위를 초과합니다.\");\n}"
      },
      "codeExamples": {
        "bad": "// ❌ 정수형 오버플로우로 잘못된 배열 크기 산출\nint size = width * height;   // width=65536, height=65536 → 오버플로우 → 0\nbyte[] buf = new byte[size]; // 의도하지 않은 크기",
        "good": "// ✅ 경계 검사 후 안전하게 연산\nif (width <= 0 || height <= 0 || width > 10000 || height > 10000) {\n    throw new IllegalArgumentException(\"허용 범위 초과: \" + width + \"x\" + height);\n}\nlong size = (long) width * height;\nif (size > Integer.MAX_VALUE) {\n    throw new IllegalArgumentException(\"버퍼 크기 초과\");\n}\nbyte[] buf = new byte[(int) size];"
      }
    },
    {
      "ruleId": "DS-1.9",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "보안기능 입력값 검증",
      "cwe": [
        "CWE-807",
        "CWE-476"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "보안결정에 사용되는 입력값 검증 로직 설계",
      "relatedImplRules": [
        "IV-1.15"
      ],
      "dangerousPatterns": [
        "getParameter.*role|getParameter.*admin|getParameter.*permission"
      ],
      "remediation": {
        "strategy": "SERVER_SIDE_AUTH_CHECK",
        "description": "보안결정에 사용되는 입력값 검증 로직 설계",
        "guideRef": "PART3 제1절 9항 (p.99-103)",
        "remediationCode": "// [수정] DS-1.9 보안 결정 입력값 설계: 서버 측 세션·권한 정보만 사용\n// ❌ 취약: 클라이언트가 전달한 role 파라미터로 권한 결정\nString role = request.getParameter(\"role\");\nif (\"admin\".equals(role)) { performAdminAction(); }\n\n// ✅ 안전: 서버 세션에서만 권한 확인\nHttpSession session = request.getSession(false);\nif (session == null)\n    throw new UnauthorizedException(\"로그인이 필요합니다.\");\nUserVO user = (UserVO) session.getAttribute(\"loginUser\");\nif (user == null || !\"ADMIN\".equals(user.getRole()))\n    throw new ForbiddenException(\"관리자 권한이 없습니다.\");\nperformAdminAction();\n// Spring Security: @PreAuthorize(\"hasRole('ADMIN')\")"
      },
      "codeExamples": {
        "bad": "// ❌ 클라이언트 파라미터로 보안 결정 (우회 가능)\nString role = request.getParameter(\"role\"); // 공격자가 \"admin\" 전달 가능\nif (\"admin\".equals(role)) {\n    showAdminPage(response);\n}",
        "good": "// ✅ 서버 세션 기반 보안 결정\nHttpSession session = request.getSession(false);\nif (session == null) {\n    response.sendRedirect(\"/login\");\n    return;\n}\nString role = (String) session.getAttribute(\"role\");\nif (\"admin\".equals(role)) {\n    showAdminPage(response);\n}"
      }
