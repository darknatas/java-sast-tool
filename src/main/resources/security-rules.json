      "remediation": {
        "strategy": "CHECKSUM_VERIFY",
        "description": "다운로드된 코드·라이브러리에 대해 체크섬(SHA-256) 검증 후 실행",
        "guideRef": "PART4 제2절 15항 (p.395-399)",
        "remediationCode": "// [수정] IV-2.15 다운로드 무결성 검증: SHA-256 체크섬 확인\n// ❌ 취약: 다운로드 파일을 체크섬 없이 바로 실행\nFiles.copy(new URL(\"https://cdn.example.com/plugin.jar\")\n    .openStream(), Paths.get(\"plugin.jar\"),\n    StandardCopyOption.REPLACE_EXISTING);\n// 무결성 검증 없이 로드 → 공급망 공격(Supply Chain Attack)!\n\n// ✅ 안전: SHA-256 체크섬 검증 후 사용\nprivate static final String EXPECTED =\n    \"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855\";\nPath target = Paths.get(\"plugin.jar\");\nFiles.copy(new URL(\"https://cdn.example.com/plugin.jar\")\n    .openStream(), target, StandardCopyOption.REPLACE_EXISTING);\nbyte[] hash = MessageDigest.getInstance(\"SHA-256\")\n    .digest(Files.readAllBytes(target));\nString actual = HexFormat.of().formatHex(hash);\nif (!MessageDigest.isEqual(actual.getBytes(), EXPECTED.getBytes()))\n    throw new SecurityException(\"파일 무결성 검증 실패!\");"
      },
      "dangerousPatterns": [
        "openStream\\(\\)|URLConnection.*getInputStream"
      ],
      "codeExamples": {
        "bad": "// ❌ 무결성 검사 없이 외부 코드 다운로드 후 실행\nURL fileUrl = new URL(\"http://update.example.com/agent.jar\");\nFileUtils.copyURLToFile(fileUrl, new File(\"/app/agent.jar\"));\nRuntime.getRuntime().exec(\"java -jar /app/agent.jar\");",
        "good": "// ✅ SHA-256 해시 검증 후 실행\nURL fileUrl = new URL(\"https://update.example.com/agent.jar\");\nbyte[] data = downloadBytes(fileUrl);\nMessageDigest md = MessageDigest.getInstance(\"SHA-256\");\nString actual = DatatypeConverter.printHexBinary(md.digest(data)).toLowerCase();\nString expected = getExpectedHash(); // 신뢰된 소스에서 검증값 로드\nif (!expected.equals(actual)) {\n    throw new SecurityException(\"파일 무결성 검증 실패\");\n}\nFiles.write(Paths.get(\"/app/agent.jar\"), data);"
      }
