      ],
      "sinks": [
        "response.setHeader",
        "response.addHeader",
        "response.sendRedirect"
      ],
      "sanitizers": [
        "replaceAll.*\\\\r|\\\\n",
        "encodeForHTTP"
      ],
      "remediation": {
        "strategy": "CRLF_REMOVAL",
        "description": "HTTP 헤더 값에 CR(\\r), LF(\\n) 문자가 포함된 외부 입력값을 필터링 없이 설정하면 HTTP 응답분할 취약점이 발생한다. 공격자는 CRLF 시퀀스를 삽입하여 HTTP 응답을 분리하고 임의의 헤더·쿠키를 주입하거나 악성 HTML 응답을 캐시에 저장(캐시 포이즈닝)할 수 있다. 이를 통해 XSS 공격 실행, 세션 쿠키 조작, 중간자 공격 등의 2차 공격이 가능하다. setHeader·addHeader·sendRedirect에 사용하는 모든 입력값에서 CR/LF 및 유사 제어 문자(\\u0085, \\u2028, \\u2029)를 제거해야 한다.",
        "guideRef": "PART4 제1절 13항 (p.284-289)",
        "bad_code": "// ❌ 외부 입력값을 HTTP 헤더에 직접 삽입 (CRLF 삽입)\nString lang = request.getParameter(\"lang\");\n// lang = \"ko\\r\\nSet-Cookie: session=evil\" 같은 공격 가능\nresponse.setHeader(\"Content-Language\", lang);",
        "good_code": "// ✅ CR/LF 문자 제거 + 화이트리스트 검증\nString lang = request.getParameter(\"lang\");\nif (lang != null) {\n    lang = lang.replaceAll(\"[\\\\r\\\\n]\", \"\");\n    if (!lang.matches(\"[a-zA-Z]{2,8}(-[a-zA-Z]{2,8})?\")) {\n        lang = \"ko\";\n    }\n    response.setHeader(\"Content-Language\", lang);\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/113.html"
      }
    },
