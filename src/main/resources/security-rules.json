        "good": "// ✅ 복잡도 정책 강제: 8자 이상, 영문+숫자+특수문자\npublic void register(String id, String pw) {\n    if (pw == null || pw.length() < 8) throw new IllegalArgumentException(\"8자 이상 입력\");\n    if (!pw.matches(\".*[a-zA-Z].*\")) throw new IllegalArgumentException(\"영문자 포함 필요\");\n    if (!pw.matches(\".*\\\\d.*\"))     throw new IllegalArgumentException(\"숫자 포함 필요\");\n    if (!pw.matches(\".*[!@#$%^&*].*\")) throw new IllegalArgumentException(\"특수문자 포함 필요\");\n    userDao.insert(id, hash(pw));\n}"
      }
