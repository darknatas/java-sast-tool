      "taintAnalysis": false,
      "remediation": {
        "strategy": "AUTH_GATE_FILTER",
        "description": "모든 중요 기능 진입 전 인증 상태 확인 필터 적용",
        "guideRef": "PART4 제2절 1항 (p.314-318)",
        "remediationCode": "// [수정] IV-2.1 인증 없는 중요기능 접근 방지\n// ❌ 취약: 중요 기능 앞에 인증 검사 없음\npublic void transferMoney(String toAcc, int amt) {\n    bankService.transfer(fromAcc, toAcc, amt);  // 인증 없음!\n}\n\n// ✅ 안전: 진입 전 인증·세션 확인\npublic void transferMoney(HttpServletRequest req,\n        String toAcc, int amt) {\n    HttpSession ses = req.getSession(false);\n    if (ses == null)\n        throw new UnauthorizedException(\"로그인이 필요합니다.\");\n    UserVO user = (UserVO) ses.getAttribute(\"loginUser\");\n    if (user == null)\n        throw new UnauthorizedException(\"세션이 만료되었습니다.\");\n    bankService.transfer(user.getAccountId(), toAcc, amt);\n}\n// Spring Security:\n// .authorizeRequests().antMatchers(\"/transfer/**\").authenticated()"
      },
      "dangerousPatterns": [
        "void doPost\\(HttpServletRequest|void doGet\\(HttpServletRequest"
      ],
      "codeExamples": {
        "bad": "// ❌ 인증 확인 없이 중요 기능 접근\n@GetMapping(\"/admin/deleteUser\")\npublic String deleteUser(String userId) {\n    userService.delete(userId); // 인증 미확인\n    return \"success\";\n}",
        "good": "// ✅ 세션 인증 + 역할 권한 확인\n@GetMapping(\"/admin/deleteUser\")\npublic String deleteUser(String userId, HttpServletRequest request) {\n    HttpSession session = request.getSession(false);\n    if (session == null || !\"admin\".equals(session.getAttribute(\"role\"))) {\n        throw new SecurityException(\"접근 권한이 없습니다.\");\n    }\n    userService.delete(userId);\n    return \"success\";\n}"
      }
    },
    {
      "ruleId": "IV-2.2",
      "part": "PART4",
      "section": "보안기능",
      "name": "부적절한 인가",
      "cwe": [
        "CWE-285"
      ],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": false,
      "remediation": {
        "strategy": "RBAC_CHECK",
        "description": "기능별 권한 검사 로직 추가(RBAC/ABAC 패턴 적용)",
        "guideRef": "PART4 제2절 2항 (p.319-324)",
        "remediationCode": "// [수정] IV-2.2 부적절한 인가 방지: 역할 기반 접근 제어(RBAC)\n// ❌ 취약: 로그인 여부만 확인하고 권한 미검사\nUserVO user = (UserVO) session.getAttribute(\"loginUser\");\nif (user != null) adminService.deleteUser(targetId);\n\n// ✅ 안전: 역할(Role) 검사 + 본인 리소스 검증\nUserVO user = (UserVO) session.getAttribute(\"loginUser\");\nif (user == null)\n    throw new UnauthorizedException(\"로그인 필요\");\nif (!\"ADMIN\".equals(user.getRole()))\n    throw new ForbiddenException(\"관리자만 접근 가능\");\n// 수평적 권한 상승 방지: 본인 리소스만 수정\nif (!user.getId().equals(targetId) &&\n    !\"ADMIN\".equals(user.getRole()))\n    throw new ForbiddenException(\"본인 계정만 수정 가능\");\nadminService.deleteUser(targetId);"
      },
      "dangerousPatterns": [
        "isAdmin\\(\\)|\\.getRole\\(\\)|hasPermission\\("
      ],
      "codeExamples": {
