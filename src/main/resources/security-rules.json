      "remediation": {
        "strategy": "BOUNDS_CHECK",
        "description": "정수 연산 전 범위 검사 또는 BigInteger 사용, Math.addExact 활용",
        "guideRef": "PART4 제1절 14항 (p.290-296)",
        "remediationCode": "// [수정] IV-1.14 정수형 오버플로우 방지: 범위 검사 + 안전 연산\n// ❌ 취약: 입력값 범위 검사 없이 정수 연산\nint count = Integer.parseInt(request.getParameter(\"count\"));\nint total = count * unitPrice;  // 오버플로우 가능\n\n// ✅ 안전 방법 1: Math.multiplyExact (오버플로우 시 예외)\nint count = Integer.parseInt(request.getParameter(\"count\"));\nif (count < 1 || count > 10000)\n    throw new IllegalArgumentException(\"수량 초과 (1~10000)\");\nlong total;\ntry {\n    total = Math.multiplyExact((long) count, unitPrice);\n} catch (ArithmeticException e) {\n    throw new IllegalArgumentException(\"계산 결과 범위 초과\");\n}\n\n// ✅ 안전 방법 2: BigDecimal (금융 계산)\nBigDecimal amount = BigDecimal.valueOf(count)\n    .multiply(BigDecimal.valueOf(unitPrice));"
      },
      "dangerousPatterns": [
        "Integer\\.parseInt\\(|Long\\.parseLong\\(|\\(byte\\)\\s*\\w"
      ],
      "codeExamples": {
        "bad": "// ❌ int 연산에서 정수형 오버플로우 미검증\nint price = Integer.parseInt(request.getParameter(\"price\"));\nint qty   = Integer.parseInt(request.getParameter(\"qty\"));\nint total = price * qty; // 오버플로우 시 음수 → 요금 우회 가능",
        "good": "// ✅ long 타입 사용 또는 범위 사전 검증\nint price = Integer.parseInt(request.getParameter(\"price\"));\nint qty   = Integer.parseInt(request.getParameter(\"qty\"));\nif (price <= 0 || price > 1_000_000 || qty <= 0 || qty > 10_000) {\n    throw new IllegalArgumentException(\"입력값 범위 초과\");\n}\nlong total = (long) price * qty; // long으로 계산"
      }
    },
