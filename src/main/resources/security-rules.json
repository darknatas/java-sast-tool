      "cwe": [
        "CWE-434",
        "CWE-494"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "업로드 파일 유형·크기 검증 및 다운로드 경로 검증 설계",
      "relatedImplRules": [
        "IV-1.6"
      ],
      "dangerousPatterns": [
        "getOriginalFilename\\(\\)|getPart\\(|transferTo\\("
      ],
      "remediation": {
        "strategy": "FILE_EXTENSION_WHITELIST",
        "description": "업로드 파일 유형·크기 검증 및 다운로드 경로 검증 설계",
        "guideRef": "PART3 제1절 10항 (p.104-110)",
        "remediationCode": "// [수정] DS-1.10 파일 업/다운로드 설계: 확장자·크기·경로 검증\n// ❌ 취약: 원본 파일명 검증 없이 그대로 저장\nString name = file.getOriginalFilename();\nfile.transferTo(new File(\"/uploads/\" + name));\n\n// ✅ 안전: 확장자 화이트리스트 + 경로 검증 + 파일명 랜덤화\nSet<String> ALLOWED = Set.of(\"jpg\",\"jpeg\",\"png\",\"gif\",\"pdf\");\nString ext = FilenameUtils.getExtension(\n    file.getOriginalFilename()).toLowerCase();\nif (!ALLOWED.contains(ext))\n    throw new SecurityException(\"허용되지 않는 확장자: \" + ext);\nif (file.getSize() > 10 * 1024 * 1024)\n    throw new SecurityException(\"파일 크기 초과 (최대 10MB)\");\nString saveName = UUID.randomUUID() + \".\" + ext;\nPath dest = Paths.get(\"/var/secure-uploads\", saveName).normalize();\nif (!dest.startsWith(Paths.get(\"/var/secure-uploads\")))\n    throw new SecurityException(\"경로 탈출 시도 감지\");\nfile.transferTo(dest);"
      },
      "codeExamples": {
        "bad": "// ❌ 파일 확장자·Content-Type 검증 없이 업로드 허용\nString fileName = item.getName();\nFile dest = new File(uploadDir, fileName);\nitem.write(dest); // .jsp, .php 등 실행 파일 업로드 가능",
        "good": "// ✅ 화이트리스트 확장자 검증 + 저장명 랜덤화\nSet<String> allowed = new HashSet<>(Arrays.asList(\"jpg\", \"png\", \"pdf\"));\nString origName = item.getName();\nString ext = origName.substring(origName.lastIndexOf('.') + 1).toLowerCase();\nif (!allowed.contains(ext)) {\n    throw new SecurityException(\"허용되지 않는 파일 형식: \" + ext);\n}\nString safeName = UUID.randomUUID().toString() + \".\" + ext;\nitem.write(new File(uploadDir, safeName));"
      }
    },
