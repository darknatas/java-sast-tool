    // 제1절 입력데이터 검증 및 표현 (17개)
    {
      "ruleId": "IV-1.1",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "SQL 삽입",
      "cwe": ["CWE-89"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": [
        "request.getParameter",
        "request.getAttribute",
        "request.getQueryString",
        "request.getHeader",
        "request.getCookies",
        "getInputStream",
        "args[]"
      ],
      "sinks": [
        "Statement.executeQuery",
        "Statement.executeUpdate",
        "Statement.execute",
        "Statement.executeBatch",
        "Connection.prepareStatement",
        "createNativeQuery",
        "createQuery"
      ],
      "sanitizers": [
        "PreparedStatement",
        "setString",
        "setInt",
        "setLong",
        "setParameter",
        "escapeSQL",
        "replaceAll"
      ],
      "dangerousPatterns": [
        "String sql = .* \\+ .*",
        "stmt\\.executeQuery\\(.*\\+.*\\)",
        "\"SELECT.*\" \\+ .*",
        "\\$\\{.*\\}"
      ],
      "remediation": {
        "strategy": "USE_PREPARED_STATEMENT",
        "description": "외부 입력값을 SQL 문자열에 직접 연결(+)하면 공격자가 SQL 문법을 주입하여 인증 우회, 데이터 탈취, 데이터 변조가 가능하다. PreparedStatement의 ?·플레이스홀더를 사용하면 SQL 구조가 컴파일 시점에 확정되어 입력값이 순수 데이터로만 처리된다. MyBatis 환경에서는 ${ } 대신 #{ } 바인딩 파라미터를 사용하라.",
        "guideRef": "PART4 제1절 1항 (p.180-193)",
        "remediationCode": "// [수정] IV-1.1 SQL 삽입 방지: PreparedStatement 사용\n// ❌ 취약: String sql = \"SELECT * FROM board WHERE id='\" + userId + \"'\";\n// ✅ 안전:\nString sql = \"SELECT * FROM board WHERE id = ?\";\ntry (PreparedStatement pstmt = con.prepareStatement(sql)) {\n    pstmt.setString(1, userId);\n    try (ResultSet rs = pstmt.executeQuery()) {\n        while (rs.next()) { /* 처리 */ }\n    }\n} catch (SQLException e) {\n    log.error(\"[DB] 쿼리 실행 오류: {}\", e.getMessage(), e);\n    throw new RuntimeException(\"데이터 조회 중 오류가 발생했습니다.\", e);\n}\n// MyBatis: WHERE b_gubun = #{userId}  (${userId} 사용 금지)"
      }
    },
    {
      "ruleId": "IV-1.2",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "코드삽입",
      "cwe": ["CWE-94", "CWE-95"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": ["request.getParameter", "request.getAttribute"],
      "sinks": [
        "Runtime.exec",
        "ProcessBuilder",
        "ScriptEngine.eval",
        "Class.forName",
        "Method.invoke",
        "groovy.lang.GroovyShell.evaluate"
      ],
      "sanitizers": ["replaceAll", "matches", "Pattern.compile"],
      "remediation": {
        "strategy": "WHITELIST_VALIDATION",
        "description": "허용된 값 목록(화이트리스트)으로 입력값을 제한하고 동적 코드 실행 금지",
        "guideRef": "PART4 제1절 2항 (p.194-200)"
      }
    },
    {
      "ruleId": "IV-1.3",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "경로 조작 및 자원 삽입",
      "cwe": ["CWE-22", "CWE-99", "CWE-78"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": ["request.getParameter", "request.getAttribute", "args[]", "getenv"],
      "sinks": [
        "new File(",
        "new FileInputStream(",
        "new FileOutputStream(",
        "new FileReader(",
        "new BufferedReader(new FileReader",
        "Paths.get(",
        "new URL(",
        "openConnection",
        "ServerSocket",
        "Socket"
      ],
      "sanitizers": [
        "replaceAll",
        "getCanonicalPath",
        "startsWith",
        "Paths.get.*normalize",
        "FilenameUtils.getName"
      ],
      "dangerousPatterns": [
        "\\.\\./",
        "\\.\\.\\\\"
      ],
      "remediation": {
        "strategy": "PATH_CANONICALIZATION",
        "description": "외부 입력 파일명/경로에 '../'(상위 디렉터리 탈출), '%2e%2e%2f'(URL 인코딩) 등이 포함되면 허용된 디렉터리를 벗어나 임의 파일 접근이 가능하다. getCanonicalPath()로 경로를 정규화한 후 허용 기본 디렉터리(base directory) 내부에 있는지 Path.startsWith()로 검증하라. String.startsWith() 사용 시 /data2가 /data로 오인되는 문제가 발생하므로 반드시 Path API 사용.",
        "guideRef": "PART4 제1절 3항 (p.201-210)",
        "remediationCode": "// [수정] IV-1.3 경로 조작 방지: canonicalize 후 허용 범위 검증\nString fileName = request.getParameter(\"fileName\");\nif (fileName == null || !fileName.matches(\"^[a-zA-Z0-9._-]{1,255}$\"))\n    throw new SecurityException(\"허용되지 않는 파일명\");\nFile baseDir = new File(\"/app/uploads\").getCanonicalFile();\nFile target  = new File(baseDir, fileName).getCanonicalFile();\nif (!target.toPath().startsWith(baseDir.toPath()))\n    throw new SecurityException(\"허용되지 않는 경로 접근\");\ntry (FileInputStream fis = new FileInputStream(target)) { /* 처리 */ }"
      }
    },
    {
      "ruleId": "IV-1.4",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "크로스사이트 스크립트",
      "cwe": ["CWE-79"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": ["request.getParameter", "request.getAttribute", "request.getCookies"],
      "sinks": [
