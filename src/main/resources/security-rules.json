      ],
      "sanitizers": [
        "session.getAttribute",
        "SecurityContext"
      ],
      "remediation": {
        "strategy": "SERVER_SIDE_AUTH_CHECK",
        "description": "보안 결정은 서버 측 세션/SecurityContext에서만 수행, 클라이언트 입력값 사용 금지",
        "guideRef": "PART4 제1절 15항 (p.297-302)",
        "remediationCode": "// [수정] IV-1.15 보안 결정 입력값 방지: 클라이언트 값 사용 금지\n// ❌ 취약: 클라이언트 파라미터로 권한 결정\nString role = request.getParameter(\"role\");\nif (\"admin\".equals(role)) grantAccess();\n\n// ✅ 안전: 서버 세션·SecurityContext에서만 판단\nHttpSession session = request.getSession(false);\nif (session == null)\n    throw new UnauthorizedException(\"로그인 필요\");\nUserVO user = (UserVO) session.getAttribute(\"loginUser\");\nif (user == null || !\"ADMIN\".equals(user.getRole()))\n    throw new ForbiddenException(\"권한 없음\");\ngrantAccess();\n// Spring Security: @PreAuthorize(\"hasRole('ADMIN')\")\n// SecurityContextHolder.getContext().getAuthentication()"
      },
      "codeExamples": {
        "bad": "// ❌ 클라이언트 파라미터로 보안 결정 (은닉 필드·쿠키 조작 가능)\nString role = request.getParameter(\"role\"); // 공격자가 \"admin\" 전달\nif (\"admin\".equals(role)) { grantAdminAccess(); }",
        "good": "// ✅ 서버 세션 기반 보안 결정\nHttpSession session = request.getSession(false);\nif (session == null) { response.sendRedirect(\"/login\"); return; }\nString role = (String) session.getAttribute(\"role\");\nif (\"admin\".equals(role)) {\n    grantAdminAccess();\n}"
      }
    },
