      "sanitizers": [
        "encodeForLDAP",
        "ESAPI.encoder",
        "replaceAll"
      ],
      "remediation": {
        "strategy": "LDAP_ENCODING",
        "description": "LDAP 필터에 사용되는 입력값에 LDAP 특수문자 인코딩이 적용되지 않으면 LDAP 삽입 취약점이 발생한다. 공격자는 *(와일드카드), (, ), \\, NUL 문자를 삽입하여 LDAP 필터 로직을 변조하고, 모든 사용자 정보 조회나 인증 우회를 시도할 수 있다. Active Directory나 OpenLDAP 서버의 전체 사용자 계정 정보가 노출될 수 있어 조직 전체 보안에 위협이 된다. RFC 4515 기준으로 LDAP 특수문자를 인코딩하거나 화이트리스트 정규식으로 입력값을 제한해야 한다.",
        "guideRef": "PART4 제1절 10항 (p.264-271)",
        "bad_code": "// ❌ 외부 입력값을 LDAP 필터에 직접 삽입\nString uid = request.getParameter(\"uid\");\nString filter = \"(uid=\" + uid + \")\";\nNamingEnumeration<?> ne = ctx.search(base, filter, controls);",
        "good_code": "// ✅ LDAP 특수문자 이스케이프\nString uid = request.getParameter(\"uid\");\nString safe = uid.replaceAll(\"[\\\\\\\\*\\\\(\\\\)\\0/]\", \"\");\nif (!safe.matches(\"[a-zA-Z0-9._-]{1,64}\")) {\n    throw new IllegalArgumentException(\"허용되지 않는 UID\");\n}\nString filter = \"(uid=\" + safe + \")\";\nNamingEnumeration<?> ne = ctx.search(base, filter, controls);",
        "reference_url": "https://cwe.mitre.org/data/definitions/90.html"
      }
    },
    {
      "ruleId": "IV-1.11",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "크로스사이트 요청 위조",
      "cwe": [
        "CWE-352"
      ],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": false,
      "sources": [],
      "sinks": [
        "doPost",
        "doPut",
        "doDelete"
      ],
      "sanitizers": [
        "csrfToken",
        "validateToken",
        "SynchronizerTokenPattern"
      ],
      "remediation": {
        "strategy": "CSRF_TOKEN",
        "description": "상태 변경 요청(POST/PUT/DELETE)에 CSRF 토큰 검증이 없으면 CSRF(Cross-Site Request Forgery) 취약점이 발생한다. 공격자는 피해자가 방문하는 악성 사이트에 숨겨진 폼을 통해 피해자의 세션을 이용한 비밀번호 변경, 계좌이체, 계정 삭제 등의 요청을 서버에 전송할 수 있다. 피해자는 자신이 공격을 당하고 있는지 인식하지 못한 채 피해가 발생하는 매우 교묘한 공격이다. Synchronizer Token Pattern(CSRF 토큰 생성·검증) 또는 SameSite 쿠키 속성을 적용해야 한다.",
        "guideRef": "PART4 제1절 11항 (p.272-275)",
        "bad_code": "// ❌ CSRF 토큰 없는 상태 변경 요청\n// POST /deleteAccount — 토큰 검증 없음\npublic void deleteAccount(HttpServletRequest req) {\n    String userId = (String) req.getSession().getAttribute(\"userId\");\n    userService.delete(userId);\n}",
        "good_code": "// ✅ Synchronizer Token 패턴으로 CSRF 방어\npublic void deleteAccount(HttpServletRequest req) {\n    HttpSession session = req.getSession(false);\n    String expected = (String) session.getAttribute(\"csrfToken\");\n    String received = req.getParameter(\"csrfToken\");\n    if (expected == null || !expected.equals(received)) {\n        throw new SecurityException(\"CSRF 토큰 불일치\");\n    }\n    String userId = (String) session.getAttribute(\"userId\");\n    userService.delete(userId);\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/352.html"
      },
      "dangerousPatterns": [
        "void doPost\\(HttpServletRequest|void doPut\\(|void doDelete\\("
      ]
    },
    {
      "ruleId": "IV-1.12",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "서버사이드 요청 위조",
      "cwe": [
        "CWE-918"
      ],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
