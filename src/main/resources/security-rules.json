        "guideRef": "PART4 제1절 17항 (p.309-313)",
        "remediationCode": "// [수정] IV-1.17 포맷 스트링 삽입 방지: 포맷 문자열을 리터럴로 고정\n// ❌ 취약: 외부 입력을 String.format() 첫 인자로 사용\nString fmt = request.getParameter(\"format\");\nString out = String.format(fmt, args);  // %n, %s 등 임의 지정자 주입\n\n// ✅ 안전: 포맷 문자열은 코드에 리터럴로 고정\nString name = request.getParameter(\"name\");\nString out = String.format(\"안녕하세요, %s님!\", name);\n\n// 로그도 동일 원칙 적용\n// ❌ log.info(userInput);          → 포맷 인자 주입 가능\n// ✅ log.info(\"입력: {}\", userInput);  → 안전\n// ✅ log.info(\"입력: {}\", sanitized);  → 외부 입력도 인자로만"
      },
      "codeExamples": {
        "bad": "// ❌ 외부 입력값을 포맷 문자열로 직접 사용\nString fmt = request.getParameter(\"format\"); // \"%n%n%n...\" 공격 가능\nString output = String.format(fmt, userData);\nlog.info(fmt); // 로그에서도 동일한 문제",
        "good": "// ✅ 포맷 문자열을 상수로 고정\nString userData = request.getParameter(\"data\");\nString output = String.format(\"%s\", userData); // 포맷 문자열 고정\nlog.info(\"수신 데이터: {}\", userData); // SLF4J {}는 포맷 삽입 불가"
      }
