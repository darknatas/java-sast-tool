      ],
      "remediation": {
        "strategy": "CRLF_REMOVAL",
        "description": "HTTP 헤더 값에 포함되는 입력값에서 CR(\\r), LF(\\n) 문자 제거",
        "guideRef": "PART4 제1절 13항 (p.284-289)",
        "remediationCode": "// [수정] IV-1.13 HTTP 응답분할 방지: CR/LF 문자 제거\n// ❌ 취약: 외부 입력값을 HTTP 헤더에 직접 삽입\nString lang = request.getParameter(\"lang\");\nresponse.setHeader(\"Content-Language\", lang);\n\n// ✅ 안전: CR·LF 및 유사 제어 문자 제거 후 설정\nString lang = request.getParameter(\"lang\");\nif (lang != null) {\n    lang = lang.replaceAll(\n        \"[\\\\r\\\\n\\\\u0085\\\\u2028\\\\u2029]\", \"\");\n    if (!lang.matches(\"^[a-zA-Z]{2,8}(-[a-zA-Z0-9]{2,8})*$\"))\n        lang = \"ko\";\n    response.setHeader(\"Content-Language\", lang);\n}\n// sendRedirect URL도 동일하게 CR/LF 제거\nString loc = request.getParameter(\"returnUrl\");\nif (loc != null)\n    loc = loc.replaceAll(\"[\\\\r\\\\n]\", \"\");\nresponse.sendRedirect(loc);"
      },
      "codeExamples": {
        "bad": "// ❌ 외부 입력값을 HTTP 헤더에 직접 삽입 (CRLF 삽입)\nString lang = request.getParameter(\"lang\");\n// lang = \"ko\\r\\nSet-Cookie: session=evil\" 같은 공격 가능\nresponse.setHeader(\"Content-Language\", lang);",
        "good": "// ✅ CR/LF 문자 제거 + 화이트리스트 검증\nString lang = request.getParameter(\"lang\");\nif (lang != null) {\n    lang = lang.replaceAll(\"[\\\\r\\\\n]\", \"\");\n    if (!lang.matches(\"[a-zA-Z]{2,8}(-[a-zA-Z]{2,8})?\")) {\n        lang = \"ko\";\n    }\n    response.setHeader(\"Content-Language\", lang);\n}"
      }
    },
