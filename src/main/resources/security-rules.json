        "guideRef": "PART4 제2절 9항 (p.370-374)",
        "remediationCode": "// [수정] IV-2.9 비밀번호 복잡성 정책: 강력한 검증 구현\n// ❌ 취약: 길이만 검사하거나 너무 약한 기준\nif (password.length() < 4)\n    throw new ValidationException(\"너무 짧습니다.\");\n\n// ✅ 안전: 길이·문자 조합·금지 패턴 검증\nprivate static final Pattern PW = Pattern.compile(\n    \"^(?=.*[A-Z])(?=.*[a-z])(?=.*[0-9])(?=.*[!@#$%^&*]).{8,20}$\");\npublic void validatePassword(String pw, String userId) {\n    if (!PW.matcher(pw).matches())\n        throw new ValidationException(\n            \"8~20자, 대/소문자·숫자·특수문자 조합 필수\");\n    if (pw.equalsIgnoreCase(userId))\n        throw new ValidationException(\"아이디와 동일한 비밀번호 금지\");\n    // 이전 비밀번호 재사용 금지 (최근 3개 이력)\n    if (pwHistoryService.isRecentPassword(userId, pw))\n        throw new ValidationException(\"이전 비밀번호 재사용 불가\");\n}"
      },
