      "remediation": {
        "strategy": "LDAP_ENCODING",
        "description": "LDAP 필터에 사용되는 입력값에 LDAP 특수문자 인코딩 적용",
        "guideRef": "PART4 제1절 10항 (p.264-271)",
        "remediationCode": "// [수정] IV-1.10 LDAP 삽입 방지: 특수문자 인코딩\n// ❌ 취약: 외부 입력을 LDAP 필터에 직접 사용\nString filter = \"(&(uid=\" + userId + \")(pwd=\" + pwd + \"))\";\nctx.search(base, filter, null);\n\n// ✅ 안전: LDAP 특수문자 인코딩 (RFC 4515)\nprivate String encodeLdap(String s) {\n    return s.replace(\"\\\\\", \"\\\\5c\")\n            .replace(\"*\",  \"\\\\2a\")\n            .replace(\"(\",  \"\\\\28\")\n            .replace(\")\",  \"\\\\29\")\n            .replace(\"\\0\", \"\\\\00\");\n}\nString safeUid = encodeLdap(userId);\nString filter = \"(&(uid=\" + safeUid + \"))\";\n// 비밀번호는 필터에 넣지 말고 LDAP bind 인증으로 처리\nctx.addToEnvironment(Context.SECURITY_CREDENTIALS, pwd);\nctx.search(base, filter, null);"
      },
      "codeExamples": {
        "bad": "// ❌ 외부 입력값을 LDAP 필터에 직접 삽입\nString uid = request.getParameter(\"uid\");\nString filter = \"(uid=\" + uid + \")\";\nNamingEnumeration<?> ne = ctx.search(base, filter, controls);",
        "good": "// ✅ LDAP 특수문자 이스케이프\nString uid = request.getParameter(\"uid\");\nString safe = uid.replaceAll(\"[\\\\\\\\*\\\\(\\\\)\\0/]\", \"\");\nif (!safe.matches(\"[a-zA-Z0-9._-]{1,64}\")) {\n    throw new IllegalArgumentException(\"허용되지 않는 UID\");\n}\nString filter = \"(uid=\" + safe + \")\";\nNamingEnumeration<?> ne = ctx.search(base, filter, controls);"
      }
    },
