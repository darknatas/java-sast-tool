      "remediation": {
        "strategy": "ACCOUNT_LOCKOUT",
        "description": "로그인 실패 횟수에 제한이 없으면 무차별 대입(Brute Force) 공격과 자격증명 스터핑(Credential Stuffing) 공격에 취약해진다. 자동화 도구를 사용하면 초당 수천 번의 로그인 시도가 가능하며, 일반적인 비밀번호 목록이나 유출된 자격증명으로 많은 계정이 단시간에 탈취될 수 있다. 탈취된 계정으로 개인정보 유출, 금융 사기, 내부 시스템 침투 등의 2차 피해가 발생한다. 로그인 연속 실패 5회 시 계정 30분 잠금, CAPTCHA 도전 또는 점진적 지연(Progressive Delay) 메커니즘을 구현해야 한다.",
        "guideRef": "PART4 제2절 16항 (p.400-405)",
        "bad_code": "// ❌ 로그인 실패 횟수 제한 없음 (무차별 대입 허용)\npublic boolean login(String id, String pw) {\n    return userDao.checkPassword(id, pw);\n}",
        "good_code": "// ✅ 5회 실패 시 계정 30분 잠금\nprivate final Map<String, Integer> failMap = new ConcurrentHashMap<>();\nprivate final Map<String, Long>    lockMap = new ConcurrentHashMap<>();\npublic boolean login(String id, String pw) {\n    Long lockedUntil = lockMap.get(id);\n    if (lockedUntil != null && System.currentTimeMillis() < lockedUntil) {\n        throw new LockedException(\"계정 잠금 중\");\n    }\n    if (!userDao.checkPassword(id, pw)) {\n        int cnt = failMap.merge(id, 1, Integer::sum);\n        if (cnt >= 5) lockMap.put(id, System.currentTimeMillis() + 1800_000L);\n        return false;\n    }\n    failMap.remove(id); lockMap.remove(id);\n    return true;\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/307.html"
      },
      "dangerousPatterns": [
        "authenticate\\(|checkLogin\\(|verifyPassword\\("
