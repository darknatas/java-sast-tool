    {
      "ruleId": "DS-4.1",
      "part": "PART3",
      "section": "세션통제",
      "name": "세션 통제",
      "cwe": [
        "CWE-488"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "taintAnalysis": true,
      "description": "서비스·유틸 레이어 메서드가 HttpSession 객체 자체를 파라미터로 직접 받는 것은 보안 설계 위반이다. ① 세션 객체 전달 시 불필요한 세션 데이터 전체에 접근·변조 가능, ② Session Fixation 공격에 취약, ③ 세션 만료 시 NullPointerException 위험이 있다. 컨트롤러에서 필요한 속성값(사용자 ID, 권한 코드 등)만 추출하여 서비스 레이어에 전달해야 한다. 세션 만료 시간은 20분 이내로 설정하고, 인증 성공 후 반드시 session.invalidate() 후 새 세션을 발급하여 Session Fixation을 방지하라.",
      "relatedImplRules": [
        "IV-6.1"
      ],
      "remediation": {
        "strategy": "SESSION_DESIGN",
        "description": "컨트롤러에서 session.getAttribute(\"사용자키\")로 필요한 값만 추출 후 서비스 레이어에 전달하라. HttpSession 객체를 서비스 메서드 파라미터로 직접 선언하지 말 것. 세션 타임아웃은 web.xml 또는 setMaxInactiveInterval(1200)로 20분 설정. 로그인 성공 시 session.invalidate() 후 request.getSession(true)로 새 세션 발급.",
        "guideRef": "PART3 제4절 1항 (p.165-170)",
        "remediationCode": "// [수정] DS-4.1 세션 통제: HttpSession 객체 직접 전달 금지\n// ❌ 취약: 서비스 메서드가 HttpSession 전체를 받음\n// public BoardVO setMemberInfo(BoardVO vo, HttpSession session) { ... }\n\n// ✅ 안전: 컨트롤러에서 필요한 값만 추출하여 전달\n// [Controller]\nMemberVO memberVo = (MemberVO) session.getAttribute(\"admin\");\nif (memberVo == null) throw new UnauthorizedException(\"로그인이 필요합니다.\");\nvo = boardService.setMemberInfo(vo, memberVo.getId(), memberVo.getName());\n\n// [Service]\npublic BoardVO setMemberInfo(BoardVO vo, String userId, String userName) {\n    if (userId != null) {\n        vo.setRegId(userId);\n        vo.setRegName(userName);\n        vo.setUpdId(userId);\n        vo.setUpdName(userName);\n    }\n    return vo;\n}\n\n// [세션 만료 설정 — web.xml]\n// <session-config><session-timeout>20</session-timeout></session-config>\n\n// [Session Fixation 방지 — 로그인 성공 후]\nHttpSession oldSession = request.getSession(false);\nif (oldSession != null) oldSession.invalidate();\nHttpSession newSession = request.getSession(true);  // 새 ID 발급\nnewSession.setAttribute(\"admin\", authenticatedMember);"
      },
      "dangerousPatterns": [
        "getSession\\(|setMaxInactiveInterval|session\\.invalidate"
      ],
      "codeExamples": {
        "bad": "// ❌ 로그아웃 시 세션 미파기 → 세션 재사용 가능\n@GetMapping(\"/logout\")\npublic String logout(HttpSession session) {\n    session.removeAttribute(\"userId\"); // 세션 자체는 유지됨\n    return \"redirect:/login\";\n}",
        "good": "// ✅ 로그아웃 시 세션 완전 파기 + 새 세션 발급\n@GetMapping(\"/logout\")\npublic String logout(HttpServletRequest request, HttpServletResponse response) {\n    HttpSession session = request.getSession(false);\n    if (session != null) {\n        session.invalidate(); // 세션 완전 파기\n    }\n    // 세션 쿠키 명시적 삭제\n    Cookie cookie = new Cookie(\"JSESSIONID\", null);\n    cookie.setMaxAge(0);\n    cookie.setPath(\"/\");\n    response.addCookie(cookie);\n    return \"redirect:/login\";\n}"
      }
    },
