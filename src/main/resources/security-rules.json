      "remediation": {
        "strategy": "GENERIC_ERROR_MESSAGE",
        "description": "예외 발생 시 시스템 정보 미노출 및 안전한 처리 흐름 설계",
        "guideRef": "PART3 제3절 1항 (p.167-172)",
        "remediationCode": "// [수정] DS-3.1 예외처리 설계: 내부정보 미노출 + 안전한 처리 흐름\n// ❌ 취약: 스택트레이스·DB 오류를 클라이언트에 노출\n// e.printStackTrace(); out.println(\"오류: \" + e.getMessage());\n\n// ✅ 안전: 서버 로그 기록 + 클라이언트에 일반 메시지\n} catch (SQLException e) {\n    log.error(\"[DB] 쿼리 오류: {}\", e.getMessage(), e);\n    response.sendError(500, \"서비스 오류가 발생했습니다.\");\n}\n// Spring Boot 전역 처리기\n@ControllerAdvice\npublic class GlobalExceptionHandler {\n    @ExceptionHandler(Exception.class)\n    @ResponseStatus(HttpStatus.INTERNAL_SERVER_ERROR)\n    public Map<String, String> handle(Exception e) {\n        log.error(\"[GLOBAL] 처리되지 않은 예외\", e);\n        return Map.of(\"error\", \"서비스 오류가 발생했습니다.\");\n    }\n}"
      },
      "codeExamples": {
