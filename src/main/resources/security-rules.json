    {
      "ruleId": "DS-1.1",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "DBMS 조회 및 결과 검증",
      "cwe": ["CWE-89"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "SQL 질의문 내 입력값 유효성 검증 및 바인딩 방식 적용 설계",
      "relatedImplRules": ["IV-1.1"]
    ,
      "dangerousPatterns": ["executeQuery\\(|executeUpdate\\(|Statement.*execute"]
    },
    {
      "ruleId": "DS-1.2",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "XML 조회 및 결과 검증",
      "cwe": ["CWE-652", "CWE-643"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "XPath·XQuery 질의문에 사용되는 파라미터 필터링 또는 바인딩 설계",
      "relatedImplRules": ["IV-1.9", "IV-1.10"]
    ,
      "dangerousPatterns": ["xpath\\.evaluate|XPath\\.compile|executeXPath"]
    },
    {
      "ruleId": "DS-1.3",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "디렉토리 서비스 조회 및 결과 검증",
      "cwe": ["CWE-90"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "LDAP 질의에 사용되는 입력값 필터링 설계",
      "relatedImplRules": ["IV-1.10"]
    ,
      "dangerousPatterns": ["DirContext|InitialDirContext|\\.search\\("]
    },
    {
      "ruleId": "DS-1.4",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "시스템 자원 접근 및 명령어 수행 입력값 검증",
      "cwe": ["CWE-78", "CWE-22", "CWE-99"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "파일 경로·OS 명령어에 사용되는 외부 입력값 검증 설계",
      "relatedImplRules": ["IV-1.3", "IV-1.5"]
    ,
      "dangerousPatterns": ["Runtime\\.getRuntime\\(\\)\\.exec|new ProcessBuilder"]
    },
    {
      "ruleId": "DS-1.5",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "웹 서비스 요청 및 결과 검증",
      "cwe": ["CWE-79"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "웹 서비스 응답 데이터 XSS 필터링 및 인코딩 설계",
      "relatedImplRules": ["IV-1.4"]
    ,
      "dangerousPatterns": ["out\\.print\\(|response\\.getWriter"]
    },
    {
      "ruleId": "DS-1.6",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "웹 기반 중요 기능 수행 요청 유효성 검증",
      "cwe": ["CWE-352"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "CSRF 방지를 위한 토큰 생성 및 검증 메커니즘 설계",
      "relatedImplRules": ["IV-1.11"]
    ,
      "dangerousPatterns": ["void doPost\\(|@PostMapping"]
    },
    {
      "ruleId": "DS-1.7",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "HTTP 프로토콜 유효성 검증",
      "cwe": ["CWE-113"],
      "severity": "MEDIUM",
      "phase": "DESIGN",
      "description": "HTTP 응답분할 방지를 위한 헤더 값 검증 설계",
      "relatedImplRules": ["IV-1.13"]
    ,
      "dangerousPatterns": ["setHeader\\(|addHeader\\("]
    },
    {
      "ruleId": "DS-1.8",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "허용된 범위내 메모리 접근",
      "cwe": ["CWE-119", "CWE-190"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "버퍼 접근 범위 제한 및 정수 오버플로우 방지 설계",
      "relatedImplRules": ["IV-1.14", "IV-1.16"]
    ,
      "dangerousPatterns": ["byte\\[\\]|System\\.arraycopy|ByteBuffer"]
    },
    {
      "ruleId": "DS-1.9",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "보안기능 입력값 검증",
      "cwe": ["CWE-807", "CWE-476"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "보안결정에 사용되는 입력값 검증 로직 설계",
      "relatedImplRules": ["IV-1.15"]
    ,
      "dangerousPatterns": ["getParameter.*role|getParameter.*admin|getParameter.*permission"]
    },
    {
      "ruleId": "DS-1.10",
      "part": "PART3",
      "section": "입력데이터 검증 및 표현",
      "name": "업로드·다운로드 파일 검증",
      "cwe": ["CWE-434", "CWE-494"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "업로드 파일 유형·크기 검증 및 다운로드 경로 검증 설계",
      "relatedImplRules": ["IV-1.6"]
    ,
      "dangerousPatterns": ["getOriginalFilename\\(\\)|getPart\\(|transferTo\\("]
    },
    {
      "ruleId": "DS-2.1",
      "part": "PART3",
      "section": "보안기능",
      "name": "인증 대상 및 방식",
      "cwe": ["CWE-306"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "중요 기능에 대한 적절한 인증 수단 적용 설계",
      "relatedImplRules": ["IV-2.1"]
    ,
      "dangerousPatterns": ["HttpSession|getSession\\(|session\\.getAttribute"]
    },
    {
      "ruleId": "DS-2.2",
      "part": "PART3",
      "section": "보안기능",
      "name": "인증 수행 제한",
      "cwe": ["CWE-307"],
      "severity": "MEDIUM",
      "phase": "DESIGN",
      "description": "반복 인증 시도 제한(계정 잠금) 메커니즘 설계",
      "relatedImplRules": ["IV-2.16"]
    ,
      "dangerousPatterns": ["loginAttempt|failCount|lockAccount|attemptCount"]
    },
    {
      "ruleId": "DS-2.3",
      "part": "PART3",
      "section": "보안기능",
      "name": "비밀번호 관리",
      "cwe": ["CWE-521"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "비밀번호 복잡성 정책 및 안전한 저장 방식 설계",
      "relatedImplRules": ["IV-2.9"]
    ,
      "dangerousPatterns": ["password\\s*=\\s*\"|setPassword\\("]
    },
    {
      "ruleId": "DS-2.4",
      "part": "PART3",
      "section": "보안기능",
      "name": "중요자원 접근통제",
      "cwe": ["CWE-285", "CWE-732"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "중요 자원에 대한 접근권한 최소화 및 통제 설계",
      "relatedImplRules": ["IV-2.2", "IV-2.3"]
    ,
      "dangerousPatterns": ["setReadable\\(|setWritable\\(|PosixFilePermissions"]
    },
    {
      "ruleId": "DS-2.5",
      "part": "PART3",
      "section": "보안기능",
      "name": "암호키 관리",
      "cwe": ["CWE-321"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "암호키 생성·저장·폐기 생명주기 관리 설계",
      "relatedImplRules": ["IV-2.6"]
    ,
      "dangerousPatterns": ["KeyGenerator\\.getInstance|new SecretKeySpec|KeyStore\\.getInstance"]
    },
    {
      "ruleId": "DS-2.6",
      "part": "PART3",
      "section": "보안기능",
      "name": "암호연산",
      "cwe": ["CWE-327", "CWE-326"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "안전한 암호 알고리즘 및 충분한 키 길이 사용 설계",
      "relatedImplRules": ["IV-2.4", "IV-2.7"]
    ,
      "dangerousPatterns": ["Cipher\\.getInstance|MessageDigest\\.getInstance"]
    },
    {
      "ruleId": "DS-2.7",
      "part": "PART3",
      "section": "보안기능",
      "name": "중요정보 저장",
      "cwe": ["CWE-312", "CWE-539"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "중요정보 암호화 저장 및 쿠키 보안 속성 설계",
      "relatedImplRules": ["IV-2.5", "IV-2.12"]
    ,
      "dangerousPatterns": ["new Cookie\\(|addCookie\\("]
    },
    {
      "ruleId": "DS-2.8",
      "part": "PART3",
      "section": "보안기능",
      "name": "중요정보 전송",
      "cwe": ["CWE-319"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "중요정보 전송 시 암호화 채널(TLS) 사용 설계",
      "relatedImplRules": []
    ,
      "dangerousPatterns": ["new URL.*http://|HttpURLConnection|openConnection\\("]
    },
    {
      "ruleId": "DS-3.1",
      "part": "PART3",
      "section": "에러처리",
      "name": "예외처리",
      "cwe": ["CWE-209", "CWE-390"],
      "severity": "MEDIUM",
      "phase": "DESIGN",
      "description": "예외 발생 시 시스템 정보 미노출 및 안전한 처리 흐름 설계",
      "relatedImplRules": ["IV-4.1", "IV-4.2", "IV-4.3"]
    ,
      "dangerousPatterns": ["e\\.printStackTrace\\(\\)|catch.*Exception.*\\{"]
    },
    {
      "ruleId": "DS-4.1",
      "part": "PART3",
      "section": "세션통제",
      "name": "세션 통제",
      "cwe": ["CWE-488"],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "세션 생성·만료·재사용 방지 메커니즘 설계",
      "relatedImplRules": ["IV-6.1"]
    ,
      "dangerousPatterns": ["getSession\\(|setMaxInactiveInterval|session\\.invalidate"]
    },

    // ────────────────────────────────────────────────
    // PART4 : 구현단계 보안약점 제거 기준 (총 49개)
    // ────────────────────────────────────────────────

    // 제1절 입력데이터 검증 및 표현 (17개)
    {
      "ruleId": "IV-1.1",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "SQL 삽입",
      "cwe": ["CWE-89"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": [
        "request.getParameter",
        "request.getAttribute",
        "request.getQueryString",
        "request.getHeader",
        "request.getCookies",
        "getInputStream",
        "args[]"
      ],
      "sinks": [
        "Statement.executeQuery",
        "Statement.executeUpdate",
        "Statement.execute",
        "Statement.executeBatch",
        "Connection.prepareStatement",
        "createNativeQuery",
        "createQuery"
      ],
      "sanitizers": [
        "PreparedStatement",
        "setString",
        "setInt",
        "setLong",
        "setParameter",
        "escapeSQL",
        "replaceAll"
      ],
      "dangerousPatterns": [
        "String sql = .* \\+ .*",
        "stmt\\.executeQuery\\(.*\\+.*\\)",
        "\"SELECT.*\" \\+ .*",
        "\\$\\{.*\\}"
      ],
      "remediation": {
        "strategy": "USE_PREPARED_STATEMENT",
        "description": "PreparedStatement를 사용하여 파라미터를 바인딩하고 동적 쿼리 문자열 연결을 제거",
        "guideRef": "PART4 제1절 1항 (p.180-193)"
      }
    },
    {
      "ruleId": "IV-1.2",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "코드삽입",
      "cwe": ["CWE-94", "CWE-95"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": ["request.getParameter", "request.getAttribute"],
      "sinks": [
        "Runtime.exec",
        "ProcessBuilder",
        "ScriptEngine.eval",
        "Class.forName",
        "Method.invoke",
        "groovy.lang.GroovyShell.evaluate"
      ],
      "sanitizers": ["replaceAll", "matches", "Pattern.compile"],
      "remediation": {
        "strategy": "WHITELIST_VALIDATION",
        "description": "허용된 값 목록(화이트리스트)으로 입력값을 제한하고 동적 코드 실행 금지",
        "guideRef": "PART4 제1절 2항 (p.194-200)"
      }
    },
    {
      "ruleId": "IV-1.3",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "경로 조작 및 자원 삽입",
      "cwe": ["CWE-22", "CWE-99", "CWE-78"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": ["request.getParameter", "request.getAttribute", "args[]", "getenv"],
      "sinks": [
        "new File(",
        "new FileInputStream(",
        "new FileOutputStream(",
        "new FileReader(",
        "new BufferedReader(new FileReader",
        "Paths.get(",
        "new URL(",
        "openConnection",
        "ServerSocket",
        "Socket"
      ],
      "sanitizers": [
        "replaceAll",
        "getCanonicalPath",
        "startsWith",
        "Paths.get.*normalize",
        "FilenameUtils.getName"
      ],
      "dangerousPatterns": [
        "\\.\\./",
        "\\.\\.\\\\"
      ],
      "remediation": {
        "strategy": "PATH_CANONICALIZATION",
        "description": "경로순회 문자열(../, ..\\) 제거 후 정규화된 절대경로 비교 검증",
        "guideRef": "PART4 제1절 3항 (p.201-210)"
      }
    },
    {
      "ruleId": "IV-1.4",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "크로스사이트 스크립트",
      "cwe": ["CWE-79"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": ["request.getParameter", "request.getAttribute", "request.getCookies"],
      "sinks": [
        "response.getWriter().print",
        "response.getWriter().println",
        "out.print",
        "out.println",
        "setAttribute",
        "sendRedirect"
      ],
      "sanitizers": [
        "escapeHtml",
        "encodeForHTML",
        "StringEscapeUtils",
        "ESAPI.encoder",
        "HtmlUtils.htmlEscape"
      ],
      "remediation": {
        "strategy": "OUTPUT_ENCODING",
        "description": "출력 시 HTML 특수문자 인코딩(OWASP ESAPI 또는 Spring HtmlUtils 사용)",
        "guideRef": "PART4 제1절 4항 (p.211-222)"
      }
    },
    {
      "ruleId": "IV-1.5",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "운영체제 명령어 삽입",
      "cwe": ["CWE-78"],
      "severity": "CRITICAL",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": ["request.getParameter", "request.getAttribute", "args[]"],
      "sinks": [
        "Runtime.getRuntime().exec",
        "new ProcessBuilder(",
        "ProcessBuilder.command"
      ],
      "sanitizers": ["replaceAll", "Pattern.matches", "whitelist"],
      "remediation": {
        "strategy": "AVOID_OS_COMMAND",
        "description": "OS 명령어 직접 실행 금지; 불가피한 경우 화이트리스트 기반 입력값 검증 적용",
        "guideRef": "PART4 제1절 5항 (p.223-231)"
      }
    },
    {
      "ruleId": "IV-1.6",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "위험한 형식 파일 업로드",
      "cwe": ["CWE-434"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": false,
      "sources": ["request.getPart", "MultipartFile.getOriginalFilename"],
      "sinks": ["new File(", "transferTo", "write("],
      "sanitizers": ["endsWith", "matches", "FilenameUtils.getExtension"],
      "remediation": {
        "strategy": "FILE_EXTENSION_WHITELIST",
        "description": "허용된 확장자 목록 검증, 저장 경로를 웹 루트 외부로 설정, 파일명 랜덤화",
        "guideRef": "PART4 제1절 6항 (p.232-238)"
      }
    ,
      "dangerousPatterns": ["getOriginalFilename\\(\\)|getPart\\(|MultipartFile"]
    },
    {
      "ruleId": "IV-1.7",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "신뢰되지 않는 URL 주소로 자동접속 연결",
      "cwe": ["CWE-601"],
      "severity": "MEDIUM",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": ["request.getParameter"],
      "sinks": ["sendRedirect", "setHeader.*Location", "response.encodeRedirectURL"],
      "sanitizers": ["startsWith", "matches", "allowedDomains.contains"],
      "remediation": {
        "strategy": "REDIRECT_WHITELIST",
        "description": "리다이렉트 대상 URL을 서버 측에서 허용 목록과 비교 검증",
        "guideRef": "PART4 제1절 7항 (p.239-243)"
      }
    },
    {
      "ruleId": "IV-1.8",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "부적절한 XML 외부개체 참조",
      "cwe": ["CWE-611"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": false,
      "sources": ["request.getInputStream", "request.getReader"],
      "sinks": [
        "DocumentBuilderFactory",
        "SAXParserFactory",
        "XMLInputFactory",
        "TransformerFactory"
      ],
      "sanitizers": [
        "setFeature.*DISALLOW_DOCTYPE",
        "setExpandEntityReferences.*false",
        "setProperty.*ACCESS_EXTERNAL"
      ],
      "remediation": {
        "strategy": "DISABLE_XML_ENTITY",
        "description": "XML 파서에서 외부 엔티티 참조 및 DOCTYPE 선언을 비활성화",
        "guideRef": "PART4 제1절 8항 (p.244-250)"
      }
    ,
      "dangerousPatterns": ["DocumentBuilderFactory|SAXParserFactory|XMLInputFactory"]
    },
    {
      "ruleId": "IV-1.9",
      "part": "PART4",
      "section": "입력데이터 검증 및 표현",
      "name": "XML 삽입",
      "cwe": ["CWE-652", "CWE-643"],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": true,
      "sources": ["request.getParameter"],
      "sinks": ["XPath.evaluate", "XQuery.execute", "executeXPath"],
      "sanitizers": ["replaceAll", "encodeForXPath", "ESAPI.encoder"],
      "remediation": {
        "strategy": "PARAMETERIZED_XPATH",
        "description": "XPath 변수 바인딩 사용 또는 특수문자 필터링 적용",
        "guideRef": "PART4 제1절 9항 (p.251-263)"
      }
    },
    {
