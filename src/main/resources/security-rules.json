      ],
      "remediation": {
        "strategy": "STRONG_CRYPTO",
        "description": "안전한 암호 알고리즘 및 충분한 키 길이 사용 설계",
        "guideRef": "PART3 제2절 6항 (p.145-152)",
        "remediationCode": "// [수정] DS-2.6 암호 알고리즘 설계: 안전한 알고리즘 선택\n// ❌ 취약: DES, RC4, MD5, SHA-1 등 취약 알고리즘 사용\nCipher c = Cipher.getInstance(\"DES/ECB/PKCS5Padding\");\nMessageDigest md = MessageDigest.getInstance(\"MD5\");\n\n// ✅ 안전: AES-256-GCM (암호화), SHA-256 이상 (해시)\n// [대칭 암호화 — AES-256-GCM]\nKeyGenerator kg = KeyGenerator.getInstance(\"AES\");\nkg.init(256, new SecureRandom());\nSecretKey key = kg.generateKey();\nbyte[] iv = new byte[12];\nnew SecureRandom().nextBytes(iv);\nCipher cipher = Cipher.getInstance(\"AES/GCM/NoPadding\");\ncipher.init(Cipher.ENCRYPT_MODE, key, new GCMParameterSpec(128, iv));\nbyte[] enc = cipher.doFinal(plaintext.getBytes(\"UTF-8\"));\n// [해시 — SHA-256]\nbyte[] hash = MessageDigest.getInstance(\"SHA-256\").digest(data);"
      },
      "codeExamples": {
        "bad": "// ❌ 취약한 암호 알고리즘 사용 (DES, MD5)\nCipher cipher = Cipher.getInstance(\"DES\");\nMessageDigest md = MessageDigest.getInstance(\"MD5\");\nbyte[] hash = md.digest(password.getBytes());",
        "good": "// ✅ 안전한 알고리즘 사용 (AES-256, SHA-256)\nCipher cipher = Cipher.getInstance(\"AES/GCM/NoPadding\");\nGCMParameterSpec spec = new GCMParameterSpec(128, iv);\ncipher.init(Cipher.ENCRYPT_MODE, secretKey, spec);\n// 패스워드 해시: PBKDF2 사용\nSecretKeyFactory skf = SecretKeyFactory.getInstance(\"PBKDF2WithHmacSHA256\");\nKeySpec ks = new PBEKeySpec(password.toCharArray(), salt, 310000, 256);\nbyte[] hash = skf.generateSecret(ks).getEncoded();"
      }
    },
