      "codeExamples": {
        "bad": "// ❌ 종료 조건 없는 재귀 → StackOverflowError\npublic int factorial(int n) {\n    return n * factorial(n - 1); // n <= 0 검사 없음\n}\n// ❌ 종료 조건 없는 반복문 → 무한루프\nwhile (true) {\n    processNextItem(); // 탈출 조건 없음\n}",
        "good": "// ✅ 재귀: 기저 조건 + 최대 깊이 제한\npublic int factorial(int n) {\n    if (n < 0 || n > 20) throw new IllegalArgumentException(\"범위 초과: \" + n);\n    if (n <= 1) return 1;\n    return n * factorial(n - 1);\n}\n// ✅ 반복문: 명시적 상한 조건\nint maxIter = 10_000;\nfor (int i = 0; i < maxIter && hasNextItem(); i++) {\n    processNextItem();\n}"
      }
