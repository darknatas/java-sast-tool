      "cwe": [
        "CWE-285",
        "CWE-732"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "description": "중요 자원에 대한 접근권한 최소화 및 통제 설계",
      "relatedImplRules": [
        "IV-2.2",
        "IV-2.3"
      ],
      "dangerousPatterns": [
        "setReadable\\(|setWritable\\(|PosixFilePermissions"
      ],
      "remediation": {
        "strategy": "LEAST_PRIVILEGE",
        "description": "중요 자원에 대한 접근권한 최소화 및 통제 설계",
        "guideRef": "PART3 제2절 4항 (p.131-137)",
        "remediationCode": "// [수정] DS-2.4 중요자원 접근통제 설계: 최소 권한 원칙\n// ❌ 취약: 파일에 모든 사용자 읽기/쓰기 권한 부여\nFile cfg = new File(\"/app/config/db.properties\");\ncfg.setReadable(true, false);  // everyone readable\ncfg.setWritable(true, false);  // everyone writable\n\n// ✅ 안전: 소유자만 접근 가능하도록 제한\nimport java.nio.file.attribute.*;\nPath cfgPath = Paths.get(\"/app/config/db.properties\");\nSet<PosixFilePermission> perms =\n    PosixFilePermissions.fromString(\"rw-------\");\nFiles.setPosixFilePermissions(cfgPath, perms);\n\n// 임시 파일도 최소 권한으로 생성\nPath temp = Files.createTempFile(\"upload_\", \".tmp\",\n    PosixFilePermissions.asFileAttribute(\n        PosixFilePermissions.fromString(\"rw-------\")));\n// 앱 실행 계정을 전용 서비스 계정으로 분리 (root 실행 금지)"
      },
      "codeExamples": {
        "bad": "// ❌ 로그인 여부만 확인, 자원 소유권 미검증\n@GetMapping(\"/document/{id}\")\npublic Document getDoc(@PathVariable Long id, HttpSession session) {\n    if (session.getAttribute(\"userId\") == null) throw new UnauthorizedException();\n    return docService.findById(id); // 타인 문서 접근 가능\n}",
        "good": "// ✅ 자원 소유자 또는 권한 확인\n@GetMapping(\"/document/{id}\")\npublic Document getDoc(@PathVariable Long id, HttpSession session) {\n    Long userId = (Long) session.getAttribute(\"userId\");\n    if (userId == null) throw new UnauthorizedException();\n    Document doc = docService.findById(id);\n    if (!doc.getOwnerId().equals(userId)) {\n        throw new ForbiddenException(\"접근 권한이 없습니다.\");\n    }\n    return doc;\n}"
      }
    },
