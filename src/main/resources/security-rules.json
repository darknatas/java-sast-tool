      "remediation": {
        "strategy": "FILE_EXTENSION_WHITELIST",
        "description": "허용된 확장자 목록 검증, 저장 경로를 웹 루트 외부로 설정, 파일명 랜덤화",
        "guideRef": "PART4 제1절 6항 (p.232-238)",
        "remediationCode": "// [수정] IV-1.6 파일 업로드 보안: 확장자·크기·경로 검증\n// ❌ 취약: 원본 파일명 검증 없이 저장\nString name = file.getOriginalFilename();\nfile.transferTo(new File(\"/uploads/\" + name));\n\n// ✅ 안전: 화이트리스트 + 크기 제한 + 파일명 랜덤화\nprivate static final Set<String> ALLOWED =\n    Set.of(\"jpg\",\"jpeg\",\"png\",\"gif\",\"hwp\",\"pdf\",\"xlsx\");\nString ext = FilenameUtils.getExtension(\n    file.getOriginalFilename()).toLowerCase();\nif (!ALLOWED.contains(ext))\n    throw new SecurityException(\"허용되지 않는 확장자: \" + ext);\nif (file.getSize() > 10 * 1024 * 1024)\n    throw new SecurityException(\"파일 크기 초과 (최대 10MB)\");\nString saveName = UUID.randomUUID() + \".\" + ext;\nPath dest = Paths.get(\"/var/secure-uploads\", saveName).normalize();\nif (!dest.startsWith(Paths.get(\"/var/secure-uploads\")))\n    throw new SecurityException(\"경로 탈출 시도 감지\");\nfile.transferTo(dest);"
      },
      "dangerousPatterns": [
        "getOriginalFilename\\(\\)|getPart\\(|MultipartFile"
      ],
      "codeExamples": {
        "bad": "// ❌ 파일 확장자 검증 없이 업로드 허용\nString fileName = fileItem.getName();\nFile dest = new File(uploadDir + \"/\" + fileName);\nfileItem.write(dest); // .jsp 등 실행 파일 업로드 가능",
        "good": "// ✅ 화이트리스트 확장자 검증 + 저장명 UUID 랜덤화\nSet<String> allowed = new HashSet<>(Arrays.asList(\"jpg\", \"png\", \"gif\", \"pdf\"));\nString origName = fileItem.getName();\nint dotIdx = origName.lastIndexOf('.');\nString ext = (dotIdx >= 0) ? origName.substring(dotIdx + 1).toLowerCase() : \"\";\nif (!allowed.contains(ext)) {\n    throw new SecurityException(\"허용되지 않는 파일 형식\");\n}\nString safeName = UUID.randomUUID().toString() + \".\" + ext;\nfileItem.write(new File(uploadDir, safeName));"
      }
