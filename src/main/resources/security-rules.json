        "strategy": "SESSION_ISOLATION",
        "description": "스레드 로컬 또는 요청별 세션 격리, 공유 객체에 사용자 데이터 저장 금지",
        "guideRef": "PART4 제6절 1항 (p.469-475)",
        "remediationCode": "// [수정] IV-6.1 세션 데이터 격리: static 세션 공유 금지\n// ❌ 취약: static 필드에 세션 저장 (스레드 간 데이터 혼용)\n// class UserService { private static HttpSession s; }  // 위험!\n\n// ✅ 안전: 요청 단위로 세션 조회, static 공유 금지\npublic class UserService {\n    public UserVO getUser(HttpServletRequest req) {\n        HttpSession ses = req.getSession(false);\n        return ses != null\n            ? (UserVO) ses.getAttribute(\"loginUser\") : null;\n    }\n}\n// ThreadLocal 사용 시 반드시 finally에서 제거\nThreadLocal<UserVO> holder = new ThreadLocal<>();\ntry {\n    holder.set(getUser(request));\n    processRequest();\n} finally {\n    holder.remove();  // 스레드 풀 재사용 시 이전 데이터 노출 방지\n}"
      },
      "dangerousPatterns": [
        "static.*HttpSession|public static.*Session"
      ],
      "codeExamples": {
        "bad": "// ❌ 로그아웃 후 세션 데이터 잔존 → 세션 재사용으로 타인 정보 노출\n@GetMapping(\"/logout\")\npublic String logout(HttpSession session) {\n    session.removeAttribute(\"userId\"); // 세션 자체가 유지됨\n    return \"redirect:/login\";\n}",
        "good": "// ✅ 세션 완전 파기 후 새 세션 발급\n@GetMapping(\"/logout\")\npublic String logout(HttpServletRequest request) {\n    HttpSession session = request.getSession(false);\n    if (session != null) {\n        session.invalidate();\n    }\n    return \"redirect:/login\";\n}"
      }
