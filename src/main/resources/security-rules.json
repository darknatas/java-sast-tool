        "good": "// ✅ HTML 인코딩 후 출력\nString name = request.getParameter(\"name\");\nString safe = name.replace(\"&\", \"&amp;\").replace(\"<\", \"&lt;\")\n                  .replace(\">\", \"&gt;\").replace(\"\\\"\", \"&quot;\")\n                  .replace(\"'\", \"&#x27;\");\nout.println(\"<div>\" + safe + \"</div>\");\n// OWASP Java Encoder: Encode.forHtml(name)"
      }
