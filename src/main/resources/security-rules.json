    {
      "ruleId": "DS-4.1",
      "part": "PART3",
      "section": "세션통제",
      "name": "세션 통제",
      "cwe": [
        "CWE-488"
      ],
      "severity": "HIGH",
      "phase": "DESIGN",
      "taintAnalysis": true,
      "description": "서비스·유틸 레이어 메서드가 HttpSession 객체 자체를 파라미터로 직접 받는 것은 보안 설계 위반이다. ① 세션 객체 전달 시 불필요한 세션 데이터 전체에 접근·변조 가능, ② Session Fixation 공격에 취약, ③ 세션 만료 시 NullPointerException 위험이 있다. 컨트롤러에서 필요한 속성값(사용자 ID, 권한 코드 등)만 추출하여 서비스 레이어에 전달해야 한다. 세션 만료 시간은 20분 이내로 설정하고, 인증 성공 후 반드시 session.invalidate() 후 새 세션을 발급하여 Session Fixation을 방지하라.",
      "relatedImplRules": [
        "IV-6.1"
      ],
      "remediation": {
        "strategy": "SESSION_DESIGN",
        "description": "HttpSession 객체를 서비스·유틸 레이어로 직접 전달하거나, 세션 만료·고정 공격(Session Fixation)에 대한 방어가 없으면 세션 보안 취약점이 발생한다. 공격자는 Session Fixation 공격으로 피해자의 세션 ID를 미리 알고 있는 값으로 고정하거나, 세션 파기 없이 로그아웃된 세션을 재사용하여 다른 사용자로 위장할 수 있다. 서비스 레이어에 HttpSession이 전달되면 불필요한 세션 데이터 전체에 접근·변조가 가능해 설계 원칙을 위반한다. 설계 단계에서 컨트롤러에서 필요한 값만 추출하여 전달하고, 로그인 성공 시 새 세션을 발급하며, 타임아웃을 20분 이내로 설정해야 한다.",
        "guideRef": "PART3 제4절 1항 (p.165-170)",
        "bad_code": "// ❌ 로그아웃 시 세션 미파기 → 세션 재사용 가능\n@GetMapping(\"/logout\")\npublic String logout(HttpSession session) {\n    session.removeAttribute(\"userId\"); // 세션 자체는 유지됨\n    return \"redirect:/login\";\n}",
        "good_code": "// ✅ 로그아웃 시 세션 완전 파기 + 새 세션 발급\n@GetMapping(\"/logout\")\npublic String logout(HttpServletRequest request, HttpServletResponse response) {\n    HttpSession session = request.getSession(false);\n    if (session != null) {\n        session.invalidate(); // 세션 완전 파기\n    }\n    // 세션 쿠키 명시적 삭제\n    Cookie cookie = new Cookie(\"JSESSIONID\", null);\n    cookie.setMaxAge(0);\n    cookie.setPath(\"/\");\n    response.addCookie(cookie);\n    return \"redirect:/login\";\n}",
        "reference_url": "https://cwe.mitre.org/data/definitions/488.html"
      },
      "dangerousPatterns": [
        "getSession\\(|setMaxInactiveInterval|session\\.invalidate"
      ]
    },
