      "cwe": [
        "CWE-611"
      ],
      "severity": "HIGH",
      "phase": "IMPLEMENTATION",
      "taintAnalysis": false,
      "sources": [
        "request.getInputStream",
        "request.getReader"
      ],
      "sinks": [
        "DocumentBuilderFactory",
        "SAXParserFactory",
        "XMLInputFactory",
        "TransformerFactory"
